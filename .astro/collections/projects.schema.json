{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "nextProject": {
      "type": "string"
    },
    "halfWidthImage": {
      "type": "string"
    },
    "summaryText": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "team": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "tools": {
      "type": "string"
    },
    "headerImage": {
      "type": "string"
    },
    "skills": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "impact": {
      "type": "string"
    },
    "designTalkthroughUrl": {
      "type": "string"
    },
    "prototypeEmbed": {
      "type": "string"
    },
    "videoWalkthroughUrl": {
      "type": "string"
    },
    "videoEmbed": {
      "type": "string"
    },
    "designHighlights": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "caption": {
            "type": "string"
          }
        },
        "required": [
          "title"
        ]
      }
    },
    "resultsGallery": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "buttons": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "style": {
            "default": "black",
            "type": "string",
            "enum": [
              "black",
              "white"
            ]
          }
        },
        "required": [
          "label",
          "url"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}