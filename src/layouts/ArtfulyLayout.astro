    amplitude.init('41704051c12b3b7ac2b4ba75350ad077');
  </script>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-TRBHL7V');</script>
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-QNHJCFV2NH"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-QNHJCFV2NH');</script>
  <!-- Kit.com email signup -->
  <script async data-uid="ded77907e0" src="https://artfuly.ck.page/ded77907e0/index.js"></script>
  <!-- Amplitude session replay -->
  <script src="https://cdn.amplitude.com/libs/analytics-browser-2.11.1-min.js.gz"></script>
  <script src="https://cdn.amplitude.com/libs/plugin-session-replay-browser-1.8.0-min.js.gz"></script>
  <script>window.amplitude.add(window.sessionReplay.plugin({sampleRate:1}));window.amplitude.init('41704051c12b3b7ac2b4ba75350ad077',{"autocapture":{"elementInteractions":true}});</script>
</head>
<body>

  <!-- NAV -->
  <div data-animation="over-right" data-collapse="medium" role="banner" class="navbar-3 w-nav">
    <div class="container-navbar w-container">
      <a href="/" class="brand-3 w-nav-brand" aria-label="home">
        <img src="/images/site/63089402c3ac2fd2d3c1f4d8_Artfuly-2022-round-logo.png" loading="lazy" width="Auto" height="Auto" alt="Artfuly logo" class="image-33" />
      </a>
      <nav role="navigation" class="nav-menu-3 w-nav-menu">
        <a href="/" class="navbar w-nav-link">1:1 Tutor / Mentor</a>
        <a href="/design-resources" class="navbar w-nav-link">Resources</a>
        <a href="/tools" class="navbar w-nav-link">Tools</a>
        <a href="https://artfuly.thinkific.com/collections" target="_blank" rel="noopener" class="navbar w-nav-link">Design Courses ↗</a>
        <div class="spacer _16"></div>
        <a href="#email-signup" class="a-button-navy-on-teal-nav small-text w-nav-link">The Design Edge Email</a>
      </nav>
      <div class="menu-button-4 w-nav-button" aria-label="menu" role="button" tabindex="0" id="artfuly-hamburger">
        <div class="icon-3 w-icon-nav-menu"></div>
      </div>
    </div>
    <!-- Mobile overlay — direct child of w-nav so it can be full-width -->
    <div id="artfuly-nav-overlay">
      <nav role="navigation" class="nav-menu-3 w-nav-menu" id="artfuly-nav-overlay-menu">
        <a href="/" class="navbar w-nav-link">1:1 Tutor / Mentor</a>
        <a href="/design-resources" class="navbar w-nav-link">Resources</a>
        <a href="/tools" class="navbar w-nav-link">Tools</a>
        <a href="https://artfuly.thinkific.com/collections" target="_blank" rel="noopener" class="navbar w-nav-link">Design Courses ↗</a>
        <div class="spacer _16"></div>
        <a href="#email-signup" class="a-button-navy-on-teal-nav small-text w-nav-link">The Design Edge Email</a>
      </nav>
    </div>
  </div>

  <slot />

  <!-- CONTACT / PREFOOTER -->
  <div class="homecontactsection">
    <div class="homecontact-header">
      <h6 class="heading-41">Discuss your learning goals</h6>
      <a href="https://form.typeform.com/to/BKGZ5Rsn" target="_blank" rel="noopener" class="tutor-btn tutor-btn--coral">Book a time</a>
    </div>
    <div class="homecontact-body">
      <h6 class="heading-40">...or ask a question</h6>
      <div class="form-block w-form" id="homepage-form-block">
        <form id="Homepage-Form" name="Homepage Form" class="form">
          <input class="question-form-field w-input" maxlength="256" name="Message" placeholder="" type="text" id="Message-2">
          <label for="Name-4" class="field-label-4">Your name</label>
          <input class="form-field w-input" maxlength="256" name="Name" placeholder="" type="text" id="Name-4" required>
          <label for="Email-4" class="field-label-5">Your e-mail address</label>
          <input class="form-field w-input" maxlength="256" name="Email" placeholder="" type="email" id="Email-4" required>
          <div class="a-div-right-align">
            <input type="submit" class="a-button-navy-on-teal w-button" value="Send it!">
          </div>
        </form>
        <div id="homepage-form-success" style="display:none; font-family:'Montserrat',sans-serif; font-size:16px; color:#233030; padding: 16px 0;">
          <strong>Received!</strong><br>A reply will be with you shortly!
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER — wave SVG overlaps prefooter via negative margin -->
  <div class="section-11">
    <a href="/" class="w-inline-block">
      <img src="/images/site/63089402c3ac2fd2d3c1f4d8_Artfuly-2022-round-logo.png" loading="lazy" alt="Artfuly logo" class="image-11" />
    </a>
  </div>
  <div class="section-12">
    <div class="section-12__left">
      <a href="/about" class="footer-links">About</a>
      <a href="mailto:hi@artfuly.com?subject=Website%20enquiry" class="footer-links">Send an Email</a>
    </div>
    <div class="section-12__center">
      <div class="section-12__icons">
        <a href="https://www.youtube.com/@artfulydesign" target="_blank" rel="noopener" class="w-inline-block">
          <img src="/images/site/65f2a9639a01f0c2245fe869_Youtube_icon.svg" loading="lazy" alt="Follow Artfuly on Youtube" class="image-12" />
        </a>
        <a href="https://www.linkedin.com/company/artfuly" target="_blank" rel="noopener" class="w-inline-block">
          <img src="/images/site/65f2a8f59e6211e5ba585742_linkedin_icon.svg" loading="lazy" alt="Follow Artfuly on LinkedIn" class="image-12" />
        </a>
        <a href="https://artfuly.click/events" target="_blank" rel="noopener" class="w-inline-block">
          <img src="/images/site/65f2a99f82a99319fee83be1_Eventbrite_icon.svg" loading="lazy" alt="Artfuly on Eventbrite" class="image-12" />
        </a>
      </div>
    </div>
    <div class="section-12__right">
      <a href="/privacy" class="footer-links">Privacy</a>
      <a href="/impressum" class="footer-links">Impressum</a>
    </div>
  </div>
  <div class="section-14">
    <div class="container-1216 w-container">
      <div class="div-block-151">
        <div class="copyright-footer">© Artfuly 2026</div>
      </div>
    </div>
  </div>

  <script>
    // If #email-signup doesn't exist on this page, redirect to homepage section
    document.querySelectorAll('a[href="#email-signup"]').forEach(btn => {
      btn.addEventListener('click', e => {
        if (!document.getElementById('email-signup')) {
          e.preventDefault();
          window.location.href = '/#email-signup';
        }
      });
    });
  </script>

  <script>
    // Homepage contact form — inline success, no redirect
    const contactForm = document.getElementById('Homepage-Form');
    if (contactForm) {
      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(contactForm);
        try {
          await fetch('https://formspree.io/f/mkoabvyv', {
            method: 'POST',
            body: data,
            headers: { Accept: 'application/json' },
          });
        } catch (_) {}
        contactForm.style.display = 'none';
        document.getElementById('homepage-form-success').style.display = 'block';
      });
    }

    // Active nav highlight — match current path to nav links
    (() => {
      const path = window.location.pathname.replace(/\/$/, '') || '/';
      document.querySelectorAll('.navbar-3 .navbar.w-nav-link, #artfuly-nav-overlay .navbar.w-nav-link').forEach(a => {
        const href = a.getAttribute('href')?.replace(/\/$/, '') || '';
        if (href && href !== '#email-signup' && (path === href || path.startsWith(href + '/'))) {
          a.style.color = '#048ba2';
          a.style.fontWeight = '500';
        }
      });
    })();

    const btn = document.getElementById('artfuly-hamburger');
    const overlay = document.getElementById('artfuly-nav-overlay');
    const overlayMenu = document.getElementById('artfuly-nav-overlay-menu');
    if (btn && overlay) {
      btn.addEventListener('click', () => {
        const open = overlay.style.display === 'block';
        if (open) {
          overlay.style.display = 'none';
          overlayMenu.removeAttribute('data-nav-menu-open');
          btn.classList.remove('w--open');
        } else {
          overlay.style.display = 'block';
          overlayMenu.setAttribute('data-nav-menu-open', '');
          btn.classList.add('w--open');
        }
      });
      // Close on link click
      overlay.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          overlay.style.display = 'none';
          overlayMenu.removeAttribute('data-nav-menu-open');
          btn.classList.remove('w--open');
        });
      });
    }
  </script>
</body>
</html>
