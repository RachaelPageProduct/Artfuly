---
import RPNav from '../components/RPNav.astro';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Rachael Page — Product Designer' } = Astro.props;
const canonicalURL = `https://artfuly.com${Astro.url.pathname}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon-rp.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-rp.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon-rp.png" />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Barlow+Condensed:wght@400;500;600&family=Parisienne&display=swap" rel="stylesheet" />
  <slot name="head" />
  <link rel="stylesheet" href="/styles/global.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js" defer></script>
  <!-- ShareThis -->
  <script type='text/javascript' src='https://platform-api.sharethis.com/js/sharethis.js#property=6422bedbfbfd84001b9fc051&product=inline-share-buttons' async='async'></script>
  <!-- Amplitude -->
