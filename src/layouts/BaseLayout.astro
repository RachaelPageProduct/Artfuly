---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Rachael Page — Product Designer' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js" defer></script>
</head>
<body>
  <header>
    <nav class="site-nav">
      <a href="/rachael-page/" class="logo">RP</a>
      <ul class="nav-list">

        <li><a href="/rachael-page/#about">About</a></li>

        <!-- Product Design dropdown -->
        <li class="nav-dropdown">
          <a href="/work/all">Product Design <span class="nav-chevron">▾</span></a>
          <ul class="nav-submenu">
            <li><a href="/work/all">All Work</a></li>
            <li><a href="/work/ux-design">UX &amp; Research</a></li>
            <li><a href="/work/ui-design">UI Design</a></li>
            <li><a href="/work/product-design">Strategy &amp; IA</a></li>
            <li><a href="/work/apps">Native Apps &amp; PWAs</a></li>
            <li><a href="/work/marketing">Marketing &amp; SEO</a></li>
            <li><a href="/work/development">Development</a></li>
          </ul>
        </li>

        <!-- Creative Work dropdown -->
        <li class="nav-dropdown">
          <a href="/creative-work/surface-pattern-design/">Creative Work <span class="nav-chevron">▾</span></a>
          <ul class="nav-submenu">
            <li class="nav-submenu-heading">Surface Pattern Design</li>
            <li><a href="/creative-work/surface-pattern-design/">All Collections</a></li>
            <li><a href="/creative-work/surface-pattern-design/alhambra-haven">Alhambra Haven</a></li>
            <li class="nav-submenu-divider"></li>
            <li><a href="/work/motion-design-animation">Motion Design</a></li>
            <li><a href="/work/graphic-design">Graphic Design</a></li>
          </ul>
        </li>

        <li><a href="https://artfuly.com" target="_blank" rel="noopener">Teaching ↗</a></li>
        <li><a href="/rachael-page/#contact">Contact</a></li>

        <li>
          <a href="https://www.linkedin.com/in/rachaelpage" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </li>

      </ul>
    </nav>
  </header>

  <slot />

  <section class="contact-section" id="contact">
    <h2>Get in Touch</h2>
    <p>Open to freelance projects, product design roles, and collaborations.</p>
    <div class="contact-actions">
      <a href="mailto:artfulydesign@gmail.com?subject=Enquiry%20from%20your%20portfolio" class="btn btn-white">Email Rachael</a>
      <a href="/meeting" class="btn btn-white">Book a Meeting</a>
    </div>
  </section>

  <footer class="site-footer">
    <p>© Rachael Page 2025</p>
  </footer>
</body>
</html>
