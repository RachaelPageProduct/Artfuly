</head>
<body>

  <RPNav />

  <div class="nav-content-offset">
    <slot />
  </div>

  <section class="contact-section" id="contact">
    <h2>Get in Touch</h2>
    <div class="contact-actions">
      <a href="mailto:artfulydesign@gmail.com?subject=Enquiry%20from%20your%20portfolio" class="btn btn-dark" onclick="navigator.clipboard.writeText('artfulydesign@gmail.com')">Email me</a>
      <a href="#" class="btn btn-outline" fs-copyclip-element="click" fs-copyclip-text="artfulydesign@gmail.com" onclick="navigator.clipboard.writeText('artfulydesign@gmail.com');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy Email',2000);return false;">Copy Email</a>
      <a href="/meeting" class="btn btn-dark">Book a meeting</a>
    </div>
    <a href="https://www.linkedin.com/in/rachaelpage" target="_blank" rel="noopener" aria-label="LinkedIn" class="contact-linkedin">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
  </section>

  <footer class="site-footer">
    <p>© Rachael Page 2026</p>
  </footer>
</body>
</html>
