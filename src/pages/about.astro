---
import ArtfulyLayout from '../layouts/ArtfulyLayout.astro';
---

<ArtfulyLayout
  title="About Artfuly — Rachael Page, UX & Product Design Tutor"
  description="Artfuly is run by Rachael Page — 30 years of professional UX and product design experience, based near Berlin."
>

<style>
  /* ── Hero ── */
  .about-hero {
    background: #048ba2;
    padding: 96px 24px 80px;
    text-align: center;
  }
  .about-hero__eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin: 0 0 20px;
  }
  .about-hero__h1 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .about-hero__sub {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 400;
    color: rgba(255,255,255,0.72);
    margin: 0 auto;
    max-width: 640px;
    line-height: 1.6;
  }

  /* ── Intro strip ── */
  .about-intro {
    background-color: var(--a-mid-grey);
    background-image:
      linear-gradient(rgba(230,255,255,0.88), rgba(230,255,255,0.88)),
      url(/images/webflow-cdn/5f91b822b2735eec2a828fe6_pexels-mentatdgt-1311518.jpg);
    background-position: center;
    background-size: cover;
    background-attachment: fixed;
    padding: 80px 24px;
  }
  .about-intro__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .about-intro p {
    font-family: 'Merriweather', serif;
    font-size: 1.05rem;
    line-height: 1.85;
    color: #233030;
    margin: 0 0 20px;
  }
  .about-intro p:last-child { margin-bottom: 0; }
  .about-intro__infinite {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #3ba89c;
    margin-top: 28px !important;
  }

  /* ── Bio section ── */
  .about-bio {
    background: #fff;
    padding: 80px 24px;
  }
  .about-bio__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .about-bio__label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #3ba89c;
    margin: 0 0 12px;
  }
  .about-bio__h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #233030;
    margin: 0 0 28px;
    line-height: 1.2;
  }
  .about-bio__text p {
    font-family: 'Merriweather', serif;
    font-size: 0.97rem;
    line-height: 1.85;
    color: #333;
    margin: 0 0 18px;
  }
  .about-bio__text p:last-child { margin-bottom: 0; }

  /* Expertise pills — matching rachaelpage.com style */
  .about-bio__expertise-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #888;
    margin: 36px 0 14px;
  }
  .about-bio__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }
  .about-bio__tag {
    background-color: #ceeaeb;
    border: 1px solid #fff;
    border-radius: 30px;
    outline: 1px solid #fff;
    margin: 2px 6px 2px 0;
    padding: 2px 20px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #233030;
    display: inline-flex;
    align-items: center;
  }

  /* Image side */
  .about-bio__image-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .about-bio__img {
    width: 80%;
    max-width: 340px;
    border-radius: 50%;
    object-fit: cover;
    aspect-ratio: 1/1;
    display: block;
    margin: 0 auto;
  }
  .about-bio__links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ── Credits ── */
  .about-credits {
    background: #f7f7f7;
    padding: 40px 24px;
    border-top: 1px solid #e0e0e0;
  }
  .about-credits__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .about-credits__h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 10px;
  }
  .about-credits__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about-credits__list li {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    color: #aaa;
    line-height: 1.7;
  }

  /* ── Terms of Use ── */
  .about-terms {
    background: #fff;
    padding: 64px 24px 96px;
    border-top: 1px solid #eee;
  }
  .about-terms__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .about-terms__h2 {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 800;
    color: #233030;
    margin: 0 0 8px;
  }
  .about-terms__date {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    color: #aaa;
    margin: 0 0 36px;
  }
  .about-terms h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #233030;
    margin: 32px 0 10px;
    border-top: 1px solid #eee;
    padding-top: 24px;
  }
  .about-terms h3:first-of-type { border-top: none; padding-top: 0; }
  .about-terms p,
  .about-terms li {
    font-family: 'Merriweather', serif;
    font-size: 0.9rem;
    line-height: 1.9;
    color: #555;
    margin: 0 0 14px;
  }
  .about-terms ul { padding-left: 24px; }
  .about-terms strong { color: #333; }
  .about-terms a { color: #3ba89c; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .about-bio__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .about-bio__image-col { order: -1; }
    .about-bio__img { width: 60%; max-width: 220px; }
  }
</style>

<!-- HERO -->
<section class="about-hero">
  <p class="about-hero__eyebrow">About Artfuly</p>
  <h1 class="about-hero__h1">Teaching UX &amp; Product Design</h1>
  <p class="about-hero__sub">to Design Students, Bootcampers, UX &amp; Product Designers, Developers &amp; Entrepreneurs</p>
</section>

<!-- INTRO -->
<section class="about-intro">
  <div class="about-intro__inner">
    <p>Artfuly.com is run by Rachael Page who has 30+ years professional experience in design and a degree in Product Design.</p>
    <p>Lessons are held online in video calls using Skype or the platform of your choice. Screen-sharing is often necessary during interactive lessons.</p>
    <p>In the first 25 minute session — which is free — you can get to know the tutor and explain your goals. If you then commit to some sessions, a session plan will be made for you and personalised sessions targeted to your current level and desired outcomes will be prepared and delivered, usually once or twice weekly.</p>
    <p class="about-intro__infinite">There are infinite possibilities!</p>
  </div>
</section>

<!-- BIO -->
<section class="about-bio">
  <div class="about-bio__inner">

    <div class="about-bio__text-col">
      <p class="about-bio__label">Your tutor</p>
      <h2 class="about-bio__h2">Rachael Page</h2>
      <div class="about-bio__text">
        <p>I'm a UX/Product Designer based near Berlin, working freelance &amp; remote only / location independent.</p>
        <p>I graduated from Loughborough University in the UK with a Product Design degree in 1996, and since then I've worked as a Programmer, Business Analyst, Graphic Artist, Graphic Designer, Web Designer, Senior UX Designer/Consultant and Entrepreneur.</p>
        <p>Currently I mix my time between Product Design contracts for blue-chip companies, building my design education site here, tutoring for Career Foundry and private students.</p>
        <p>Between 2005–2015 I worked for many top ad agencies in Australia — you can check out my full experience on <a href="https://www.linkedin.com/in/rachaelpage" target="_blank" rel="noopener" style="color:#3ba89c;">LinkedIn</a>.</p>
      </div>

      <p class="about-bio__expertise-label">Areas of Expertise</p>
      <div class="about-bio__tags">
        <span class="about-bio__tag">Visual Design</span>
        <span class="about-bio__tag">UX Design</span>
        <span class="about-bio__tag">User Research</span>
        <span class="about-bio__tag">User Testing</span>
        <span class="about-bio__tag">Product Strategy</span>
        <span class="about-bio__tag">Marketing Strategy</span>
        <span class="about-bio__tag">SEO</span>
        <span class="about-bio__tag">Design Tutoring</span>
        <span class="about-bio__tag">Responsive Development</span>
        <span class="about-bio__tag">Webflow</span>
        <span class="about-bio__tag">Figma</span>
        <span class="about-bio__tag">Adobe XD</span>
        <span class="about-bio__tag">Photoshop</span>
        <span class="about-bio__tag">Illustrator</span>
        <span class="about-bio__tag">InDesign</span>
      </div>

      <div class="about-bio__links" style="margin-top:36px;">
        <a href="/booking" class="tutor-btn tutor-btn--coral">1:1 Design Tutoring</a>
        <a href="/booking-mentorship" class="tutor-btn tutor-btn--ghost">1:1 Entrepreneur Mentorship</a>
      </div>
    </div>

    <div class="about-bio__image-col">
      <img
        src="/images/site/rachael-headshot.png"
        alt="Rachael Page — UX & Product Design Tutor"
        class="about-bio__img"
      />
    </div>

  </div>
</section>

<!-- CREDITS -->
<section class="about-credits">
  <div class="about-credits__inner">
    <h3 class="about-credits__h3">Image Credits</h3>
    <ul class="about-credits__list">
      <li>Mentatdgt, Singapore — image of 'Two women chatting' used on the pre-footer</li>
      <li>Fauzels — image 'Women using computers' used on the about page</li>
    </ul>
  </div>
</section>

