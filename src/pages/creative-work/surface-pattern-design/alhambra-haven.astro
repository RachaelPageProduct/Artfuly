---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const colourways = [
  { name: 'Purple Blues',  file: 'purple-blues.png'  },
  { name: 'Teal Limes',    file: 'teal-limes.png'    },
  { name: 'Purple Teals',  file: 'purple-teals.png'  },
  { name: 'Neutrals',      file: 'neutrals.png'      },
  { name: 'Bluey Greens',  file: 'bluey-greens.png'  },
];

const mockups = [
  { file: 'bedroom.jpeg',      caption: 'Wallpaper — Teal Limes colourway' },
  { file: 'curtain.jpeg',      caption: 'Curtain fabric — Teal Limes colourway' },
  { file: 'duvet.jpeg',        caption: 'Bedding — Teal Limes colourway' },
  { file: 'lime-curtains.jpeg', caption: 'Curtain fabric — Teal Limes colourway' },
  { file: 'stairs.jpeg',       caption: 'Stair runner — Neutrals colourway' },
];
---

<BaseLayout title="Alhambra Haven — Surface Pattern Collection by Rachael Page" description="A geometric surface pattern collection inspired by the intricate tilework of the Alhambra palace. Available for licensing.">

  <!-- COLLECTION HERO -->
  <section class="spd-hero">
    <div class="spd-hero-text">
      <p class="spd-collection-label">Surface Pattern Collection</p>
      <h1 class="spd-collection-name">Alhambra Haven</h1>
      <p class="spd-collection-desc">
        <!-- Description to be added -->
        A geometric surface pattern collection inspired by the intricate tilework of the Alhambra palace, Granada. Available in five colourways suitable for wallpaper, fabric, ceramic transfer, and home accessories.
      </p>
      <div class="spd-meta">
        <span>5 colourways</span>
        <span>Straight repeat</span>
        <span>Wallpaper · Fabric · Ceramics · Home Accessories</span>
      </div>
      <a href="mailto:artfulydesign@gmail.com?subject=Licensing%20enquiry%20—%20Alhambra%20Haven" class="spd-cta">
        Enquire about licensing
      </a>
    </div>
    <div class="spd-hero-image">
      <img src="/images/patterns/alhambra-haven/mockups/bedroom.jpeg" alt="Alhambra Haven wallpaper in bedroom setting" />
    </div>
  </section>

  <!-- COLOURWAYS GRID -->
  <section class="spd-colourways">
    <div class="spd-colourways-inner">
      <h2 class="spd-section-label">Colourways</h2>
      <div class="spd-grid">
        {colourways.map(c => (
          <div class="spd-swatch">
            <img src={`/images/patterns/alhambra-haven/${c.file}`} alt={`Alhambra Haven — ${c.name}`} loading="lazy" />
            <p class="spd-swatch-name">{c.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MOCKUPS / IN CONTEXT -->
  <section class="spd-mockups">
    <div class="spd-mockups-inner">
      <h2 class="spd-section-label">In Context</h2>
      <div class="spd-mockups-grid">
        {mockups.map(m => (
          <figure class="spd-mockup-item">
            <img src={`/images/patterns/alhambra-haven/mockups/${m.file}`} alt={m.caption} loading="lazy" />
            <figcaption>{m.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- LICENSING CTA -->
  <section class="spd-licensing">
    <div class="spd-licensing-inner">
      <h2>Interested in licensing this collection?</h2>
      <p>I work with brands, manufacturers, and interior product companies. Get in touch to discuss your requirements — available for exclusive and non-exclusive licensing agreements.</p>
      <a href="mailto:artfulydesign@gmail.com?subject=Licensing%20enquiry%20—%20Alhambra%20Haven" class="spd-cta">
        Email to enquire
      </a>
    </div>
  </section>

  <!-- BACK TO ALL COLLECTIONS -->
  <div class="spd-back">
    <a href="/creative-work/surface-pattern-design/">← All Collections</a>
  </div>

</BaseLayout>
