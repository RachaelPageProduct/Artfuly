---
import ArtfulyLayout from '../../layouts/ArtfulyLayout.astro';
import { getCollection } from 'astro:content';
import ResourcePills from '../../components/ResourcePills.astro';
import ArticleGrid from '../../components/ArticleGrid.astro';
import BookPromo from '../../components/BookPromo.astro';

const allArticles = await getCollection('articles');
// Only show published articles; sort newest first
const sorted = allArticles.filter(a => a.data.published).sort((a, b) => {
  if (!a.data.date && !b.data.date) return 0;
  if (!a.data.date) return 1;
  if (!b.data.date) return -1;
  return b.data.date.localeCompare(a.data.date);
});
---

<ArtfulyLayout
  title="Design Resources — Artfuly"
  description="Free articles, guides and resources for product designers and UX professionals."
>

  <!-- HERO -->
  <div class="articles-section-top">
    <div class="a-container w-container">
      <div class="a-des-insight-title" style="color:rgba(255,255,255,0.6); margin-bottom:12px; grid-area:1/1/2/5; text-align:left">FREE RESOURCES</div>
      <h1 class="h1-small-white" style="grid-area:2/1/3/5; padding-left:0">Design Resources</h1>
    </div>
  </div>

  <!-- CATEGORY FILTER PILLS -->
  <ResourcePills active="all" />

  <!-- ARTICLE GRID -->
  <ArticleGrid articles={sorted} />

  <!-- SPOONFLOWER BOOK PROMO -->
  <BookPromo />

  <!-- EMAIL CTA -->
  <section class="section_cta8" id="email-signup">
    <div class="padding-global-3">
      <div class="container-large">
        <div class="padding-section-large-3">
          <div class="cta8_component">
            <div class="cta8_content">
              <div class="max-width-large">
                <div class="margin-bottom margin-xsmall">
                  <div class="margin-bottom margin-xsmall">
                    <div class="a-des-insight-title">WEEKLY EMAIL (FREE)</div>
                  </div>
                  <h2 class="white h2insights">The Design Edge</h2>
                </div>
                <p class="white right">Keep your design skills up to date with videos,<br />AI workflows, tutorials, ways to earn $$$ and free resources</p>
                <p class="small-white-body">Unsubscribe anytime.</p>
              </div>
            </div>
            <div class="html-embed-7 w-embed w-script">
              <script async data-uid="eb98b5a075" src="https://artfuly.ck.page/eb98b5a075/index.js"></script>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</ArtfulyLayout>
