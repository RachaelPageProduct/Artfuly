---
import ArtfulyLayout from '../layouts/ArtfulyLayout.astro';
import { getCollection } from 'astro:content';

const featuredArticles = (await getCollection('articles', ({ data }) => data.featured === true && data.published !== false))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);
---

<ArtfulyLayout
  title="1:1 Tutor / Mentor — Artfuly"
  description="Fast-track UX / product design or receive personalised entrepreneur mentorship from Rachael Page — 30 years of design experience."
>

  <!-- SCROLL PROGRESS BAR -->
  <div class="tutor-progress-bar" id="tutorProgressBar"></div>

  <!-- ═══════════════════════════════════════
       HERO — full viewport, desk bg image
  ═══════════════════════════════════════ -->
  <section class="tutor-hero">
    <div class="tutor-hero__overlay"></div>
    <div class="tutor-hero__inner w-container">
      <div class="tutor-hero__text">
        <div class="tutor-hero__avatar tutor-reveal" style="--delay:0ms">
          <img src="/images/site/rachael-headshot.png" alt="Rachael Page" loading="eager" />
        </div>
        <div class="tutor-hero__label tutor-reveal" style="--delay:80ms">1:1 TUTOR / MENTOR: Rachael Page</div>
        <h1 class="tutor-hero__h1">
          <span class="tutor-reveal" style="--delay:180ms">Fast-track your</span>
          <span class="tutor-reveal" style="--delay:280ms">design career.</span>
        </h1>
        <p class="tutor-hero__sub tutor-reveal" style="--delay:380ms">
          UX / product design tutoring &amp; personalised entrepreneur mentorship
          from a designer with 30 years of real-world experience.
        </p>
        <ul class="tutor-hero__bullets">
          <li class="tutor-reveal" style="--delay:480ms">Present yourself optimally online to land the best jobs</li>
          <li class="tutor-reveal" style="--delay:540ms">Improve your Visual Design, UX/UI &amp; Graphic Design</li>
          <li class="tutor-reveal" style="--delay:600ms">Build confidence, learn new skills, tools &amp; software</li>
          <li class="tutor-reveal" style="--delay:660ms">Create a stunning portfolio that gets interviews</li>
          <li class="tutor-reveal" style="--delay:720ms">Build a website or portfolio with Claude Code, Framer, Webflow or Wix without coding</li>
          <li class="tutor-reveal" style="--delay:780ms">Design apps to launch on the app store or as a responsive web app</li>
        </ul>
        <div class="tutor-hero__ctas tutor-reveal" style="--delay:860ms">
          <a href="/booking" class="tutor-btn tutor-btn--coral">Book a session</a>
          <a href="/rachael-page/" target="_blank" rel="noopener" class="tutor-btn tutor-btn--outline">See my portfolio</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       MARQUEE STRIP
  ═══════════════════════════════════════ -->
  <div class="tutor-marquee" aria-hidden="true">
    <div class="tutor-marquee__track">
      <span>DESIGN TUTORING</span><span class="tutor-marquee__dot">·</span>
      <span>UX / PRODUCT DESIGN</span><span class="tutor-marquee__dot">·</span>
      <span>ENTREPRENEUR MENTORSHIP</span><span class="tutor-marquee__dot">·</span>
      <span>VISUAL DESIGN</span><span class="tutor-marquee__dot">·</span>
      <span>PORTFOLIO COACHING</span><span class="tutor-marquee__dot">·</span>
      <span>30 YEARS EXPERIENCE</span><span class="tutor-marquee__dot">·</span>
      <span>DESIGN TUTORING</span><span class="tutor-marquee__dot">·</span>
      <span>UX / PRODUCT DESIGN</span><span class="tutor-marquee__dot">·</span>
      <span>ENTREPRENEUR MENTORSHIP</span><span class="tutor-marquee__dot">·</span>
      <span>VISUAL DESIGN</span><span class="tutor-marquee__dot">·</span>
      <span>PORTFOLIO COACHING</span><span class="tutor-marquee__dot">·</span>
      <span>30 YEARS EXPERIENCE</span><span class="tutor-marquee__dot">·</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       WHO IT'S FOR
  ═══════════════════════════════════════ -->
  <section class="tutor-section tutor-section--light">
    <div class="w-container">
      <div class="tutor-section__label tutor-slide-up">Who it's for</div>
      <div class="tutor-who__grid">
        <div class="tutor-who__card tutor-slide-up" style="--delay:0ms">
          <div class="tutor-who__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#048ba2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M3 21v-2a9 9 0 0 1 18 0v2"/></svg>
          </div>
          <h3>UX / Product Designers</h3>
          <p>Starting out, changing careers, or levelling up from junior to senior</p>
        </div>
        <div class="tutor-who__card tutor-slide-up" style="--delay:100ms">
          <div class="tutor-who__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#048ba2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3>Developers &amp; Coders</h3>
          <p>Learning design to build better products or transition into product roles</p>
        </div>
        <div class="tutor-who__card tutor-slide-up" style="--delay:200ms">
          <div class="tutor-who__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#048ba2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Entrepreneurs &amp; Startup Teams</h3>
          <p>Creating product concepts, apps, or startup branding without a design team</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SCOTT WHITTLE TESTIMONIAL — hero quote
  ═══════════════════════════════════════ -->
  <section class="tutor-section tutor-quote-section">
    <div class="w-container">
    <div class="tutor-quote__inner">
      <div class="tutor-quote__image tutor-slide-up" style="--delay:100ms">
        <img
          src="/images/site/645ba1cadedbd33e4d5f9562_Scott-terra-homepage.png"
          alt="Scott Whittle's Terra app — 3 screens"
          loading="lazy"
          srcset="/images/site/645ba1cadedbd33e4d5f9562_Scott-terra-homepage-p-500.png 500w, /images/site/645ba1cadedbd33e4d5f9562_Scott-terra-homepage-p-800.png 800w, /images/site/645ba1cadedbd33e4d5f9562_Scott-terra-homepage-p-1080.png 1080w, /images/site/645ba1cadedbd33e4d5f9562_Scott-terra-homepage.png 2210w"
          sizes="(max-width: 767px) 100vw, 50vw"
        />
      </div>
      <div class="tutor-quote__content">
        <div class="tutor-quote__tag tutor-slide-up">ENTREPRENEUR MENTORSHIP TESTIMONIAL</div>
        <div class="tutor-quote__name-row tutor-slide-up" style="--delay:80ms">
          <span class="tutor-quote__client">Scott Whittle</span>
          <span class="tutor-quote__project">Terra app · Cape May NJ, USA · 2023</span>
        </div>
        <blockquote class="tutor-quote__text tutor-slide-up" style="--delay:160ms">
          All the generalized knowledge in the world can't help you as much as a mentor with
          decades of practical experience. Rachael can guide you through all the tricky
          decisions in the design process, focussing on your project specifically: what's
          critical, what's not, and what you haven't even thought of yet. The information
          she provides is in a whole different category, and it's invaluable.
        </blockquote>
        <div class="tutor-quote__cta tutor-slide-up" style="--delay:280ms">
          <a href="/student-successes/scott-whittle-and-terra/" class="tutor-btn tutor-btn--teal-outline">Read the Terra case study →</a>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WHAT YOU GET — 2 numbered cards
  ═══════════════════════════════════════ -->
  <section class="tutor-section tutor-section--light">
    <div class="w-container">
      <div class="tutor-section__label tutor-slide-up">What to expect from your tutor</div>
      <div class="tutor-services__grid">
        <div class="tutor-services__card tutor-slide-up" style="--delay:0ms">
          <div class="tutor-services__num">01</div>
          <h3>1:1 Design Tutoring</h3>
          <p>
            Personalised sessions covering UX, UI, product design, visual design, portfolio building,
            and no-code tools like Claude, Figma, Framer &amp; Webflow. Sessions are tailored entirely to your
            goals — no generic curriculum.
          </p>
          <div class="tutor-services__actions">
            <a href="/booking" class="tutor-btn tutor-btn--coral">Book free 30 mins</a>
            <a href="https://artfuly.thinkific.com/collections" target="_blank" rel="noopener" class="tutor-btn tutor-btn--ghost">View courses ↗</a>
          </div>
        </div>
        <div class="tutor-services__card tutor-slide-up" style="--delay:120ms">
          <div class="tutor-services__num">02</div>
          <h3>1:1 Entrepreneur Mentorship</h3>
          <p>
            You have an idea — what now? I'll help you validate it, design the MVP,
            build the right team, avoid costly mistakes, and get to market. Drawn from
            30 years building and shipping real products.
          </p>
          <div class="tutor-services__actions">
            <a href="/booking-mentorship" class="tutor-btn tutor-btn--coral">Find out more</a>
            <a href="/booking-mentorship" class="tutor-btn tutor-btn--ghost">Book a 30 min chat</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TESTIMONIALS GRID
  ═══════════════════════════════════════ -->
  <section class="tutor-section tutor-section--teal-light">
    <div class="w-container">
      <div class="tutor-section__label tutor-slide-up">Tutoring testimonials</div>
      <p class="tutor-testimonials__sub tutor-slide-up" style="--delay:80ms">Make contact to join the waitlist for private sessions</p>
      <div class="tutor-testimonials__grid">
        <div class="tutor-testimonial tutor-slide-up" style="--delay:0ms">
          <div class="tutor-testimonial__stars">
            <img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" />
          </div>
          <p>"She is an incredible teacher. I was surprised by the level of empathy Rachael has with her students — it's obvious that she really enjoys teaching. Commencing my job search, I feel prepared and am indebted."</p>
          <div class="tutor-testimonial__author">
            <img src="/images/site/tutor-testimonial-eduardo.jpeg" alt="Eduardo Hernandez" loading="lazy" />
            <div>
              <strong>Eduardo Hernandez</strong>
              <span>Mexico City, Mexico · 2023</span>
            </div>
          </div>
        </div>
        <div class="tutor-testimonial tutor-slide-up" style="--delay:100ms">
          <div class="tutor-testimonial__stars">
            <img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" />
          </div>
          <p>"Rachael patiently helped me to enhance my design skills and build a great folio. She went above and beyond to provide constructive feedback &amp; resources. She builds up your confidence."</p>
          <div class="tutor-testimonial__author">
            <img src="/images/site/tutor-testimonial-sanjana.jpeg" alt="Sanjana Bhat" loading="lazy" />
            <div>
              <strong>Sanjana Bhat</strong>
              <span>New Jersey, USA · 2022</span>
            </div>
          </div>
        </div>
        <div class="tutor-testimonial tutor-slide-up" style="--delay:200ms">
          <div class="tutor-testimonial__stars">
            <img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" /><img src="/images/site/teal-star.svg" alt="" width="16" />
          </div>
          <p>"I couldn't have asked for a better teacher over the last few months — I'm extremely grateful for your support, encouragement and guidance throughout."</p>
          <div class="tutor-testimonial__author">
            <img src="/images/site/tutor-testimonial-joyce.jpeg" alt="Joyce Echevin" loading="lazy" />
            <div>
              <strong>Joyce Echevin</strong>
              <span>London, UK · 2023</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       MEET YOUR TUTOR
  ═══════════════════════════════════════ -->
  <section class="tutor-section tutor-section--dark tutor-meet">
    <div class="w-container">
      <div class="tutor-meet__inner">
        <div class="tutor-meet__text tutor-slide-up">
          <div class="tutor-section__label">Meet your tutor</div>
          <h2>30 years of design.<br />All yours for an hour.</h2>
          <p>
            I've spent 20+ years designing products, leading teams, launching apps,
            and running my own businesses. I've been where you are — and I know what
            makes a great designer and a great product.
          </p>
          <p>
            My sessions are direct, practical, and tailored entirely to you. No fluff,
            no theory for theory's sake. Just the knowledge that will actually move
            you forward.
          </p>

        </div>
        <div class="tutor-meet__photo tutor-slide-up" style="--delay:120ms">
          <div class="tutor-meet__circle">
            <img src="/images/site/rachael-headshot.png" alt="Rachael Page" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       PORTFOLIO LINK BANNER
  ═══════════════════════════════════════ -->
  <a href="/rachael-page/" class="tutor-folio-banner tutor-slide-up">
    <span class="tutor-folio-banner__text">Want to see 30 years of design work?</span>
    <span class="tutor-folio-banner__cta">View portfolio at rachaelpage.com →</span>
  </a>

  <!-- ═══════════════════════════════════════
       TICKLISTS BRAG SECTION
  ═══════════════════════════════════════ -->
  <section class="tutor-ticklists-section">
    <div class="w-container">
    <div class="tutor-ticklists__inner">
      <div class="tutor-ticklists__text tutor-slide-up">
        <div class="tutor-ticklists__label">MVP LAUNCHED SPRING 2026</div>
        <h2 class="tutor-ticklists__heading">I also build apps.</h2>
        <p class="tutor-ticklists__body">Ticklists is my own PWA — a smarter shopping list and routine app that keeps items permanently, sorts them into your store's aisle order, and syncs live with your household. Concepted, researched, designed, built &amp; shipped solo.</p>
        <a href="https://ticklists.com" target="_blank" rel="noopener" class="tutor-btn tutor-btn--coral" style="display:inline-block;margin-top:8px;">Try Ticklists free →</a>
      </div>
      <div class="tutor-ticklists__video tutor-slide-up" style="--delay:150ms">
        <video id="ticklists-hero-video" autoplay loop muted playsinline style="width:100%;height:auto;display:block;border-radius:12px;box-shadow:0 24px 60px rgba(0,0,0,0.18);"></video>
      </div>
    </div>
    </div>
  </section>

  <script>
    (function(){
      var video = document.getElementById('ticklists-hero-video');
      if (!video) return;
      var src = 'https://vz-b91d07c1-def.b-cdn.net/62572680-9750-4895-9924-bdb4a198028c/playlist.m3u8';
      if (typeof Hls !== 'undefined' && Hls.isSupported()) {
        var hls = new Hls({ autoStartLoad: true, startLevel: -1 });
        hls.loadSource(src);
        hls.attachMedia(video);
        hls.on(Hls.Events.MANIFEST_PARSED, function() { video.play(); });
      } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
        video.src = src;
        video.play();
      }
    })();
  </script>

  <!-- TOP DESIGN RESOURCES — featured: true = "Featured on Artfuly?" in CMS -->
  <div class="section-50">
    <div class="w-container">
      <div><div class="spacer _96"></div><h2 class="navy-heading-40pt">Free Design Resources & Articles</h2></div>
      <div>
        <div class="w-dyn-list">
          <div role="list" class="collection-list-9 w-dyn-items w-row">
            {featuredArticles.map((article) => (
              <div role="listitem" class="collection-item-11 w-dyn-item w-col w-col-4">
                <a href={`/design-resources/${article.data.slug}/`} class="link-block-11 w-inline-block">
                  <h3 class="homeresourceshead3">{article.data.title}</h3>
                  <div class="div-block-71">
                    <img alt="" loading="lazy" src={article.data.thumbnailImage || article.data.heroImage} class="image-36" />
                  </div>
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- AWAY FROM THE RACE -->
  <section class="aftr-section">
    <video class="aftr-video" autoplay loop muted playsinline>
      <source src="/images/webflow-cdn/65b8dc00965457ed9e858550_IMG_6022-transcode.mp4" type="video/mp4">
      <source src="/images/webflow-cdn/65b8dc00965457ed9e858550_IMG_6022-transcode.webm" type="video/webm">
    </video>
    <div class="aftr-overlay"></div>
    <div class="aftr-content w-container">
      <h2 class="t-heading-larger">Away from the Race</h2>
      <a href="https://www.artfuly.com/travel" class="tutor-btn tutor-btn--teal aftr-btn">Work from anywhere</a>
    </div>
  </section>

  <!-- EMAIL CTA -->
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest" slot="head"></script>
  <script async data-uid="eb98b5a075" src="https://artfuly.ck.page/eb98b5a075/index.js" slot="head"></script>
  <section class="section_cta8" id="email-signup">
    <div class="padding-global-3">
      <div class="container-large">
        <div class="padding-section-large-3">
          <div class="cta8_component">
            <div class="cta8_content">
              <div class="max-width-large">
                <div class="margin-bottom margin-xsmall">
                  <div class="margin-bottom margin-xsmall">
                    <div class="a-des-insight-title">LEARN BY EMAIL (FREE)</div>
                  </div>
                  <h2 class="white h2insights">Design Principles</h2>
                </div>
                <p class="white right">Learn by watching me apply key design principles<br />1 email per week with videos &amp; free resources</p>
                <p class="small-white-body">Unsubscribe anytime.</p>
              </div>
            </div>
            <div class="html-embed-7 w-embed w-script">
              <script async data-uid="eb98b5a075" src="https://artfuly.ck.page/eb98b5a075/index.js"></script>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</ArtfulyLayout>

<style>
/* ─── Scroll progress bar ─────────────────────────────── */
.tutor-progress-bar {
  position: fixed;
  top: 0; left: 0;
  height: 3px;
  width: 0%;
  background: #84cacc;
  z-index: 9999;
  transition: width 0.1s linear;
}

/* ─── Hero ────────────────────────────────────────────── */
.tutor-hero {
  position: relative;
  background-image: url('/images/site/tutor-scott-desktop.png');
  background-size: cover;
  background-position: center 30%;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 100px 0 80px;
}
.tutor-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(4,60,75,0.88) 0%, rgba(4,80,100,0.78) 100%);
  z-index: 0;
}
.tutor-hero__inner {
  position: relative;
  z-index: 1;
  max-width: 680px;
}
.tutor-hero__avatar {
  margin-bottom: 28px;
}
.tutor-hero__avatar img {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  object-fit: cover;
  object-position: top center;
  border: 3px solid rgba(255,255,255,0.4);
  display: block;
  animation: heroPhotoIn 0.7s cubic-bezier(0.22, 0.61, 0.36, 1) 0.1s both;
}
@keyframes heroPhotoIn {
  from { opacity: 0; transform: scale(0.88); }
  to   { opacity: 1; transform: scale(1); }
}
.tutor-hero__label {
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.65);
  text-transform: uppercase;
  margin-bottom: 20px;
}
.tutor-hero__h1 {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(36px, 5vw, 68px);
  font-weight: 800;
  line-height: 1.05;
  color: #fff;
  margin: 0 0 24px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.tutor-hero__h1 span { display: block; }
.tutor-hero__sub {
  font-family: 'Montserrat', sans-serif;
  font-size: 17px;
  line-height: 1.65;
  color: rgba(255,255,255,0.82);
  margin-bottom: 28px;
  max-width: 600px;
}
.tutor-hero__bullets {
  list-style: none;
  padding: 0; margin: 0 0 36px;
  display: flex; flex-direction: column; gap: 10px;
}
.tutor-hero__bullets li {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  padding-left: 20px;
  position: relative;
}
.tutor-hero__bullets li::before {
  content: '';
  position: absolute; left: 0; top: 8px;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
}
.tutor-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; }

/* ─── Buttons ─────────────────────────────────────────── */
.tutor-btn {
  display: inline-block;
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.3px;
  padding: 12px 22px;
  border-radius: 30px;
  text-decoration: none;
  transition: all 0.18s;
  cursor: pointer;
  border: 2px solid transparent;
  white-space: nowrap;
}
.tutor-btn--coral   { background: #ee7c7b; color: #fff; }
.tutor-btn--coral:hover { background: #e5605e; }
.tutor-btn--outline { background: transparent; border-color: rgba(255,255,255,0.4); color: #fff; }
.tutor-btn--outline:hover { border-color: #fff; }
.tutor-btn--teal-outline { background: transparent; border-color: rgba(255,255,255,0.5); color: #fff; }
.tutor-btn--teal-outline:hover { background: rgba(255,255,255,0.15); border-color: #fff; }
/* ghost style moved to artfuly.css */

/* ─── Marquee ─────────────────────────────────────────── */
.tutor-marquee {
  background: #84cacc;
  overflow: hidden;
  white-space: nowrap;
  padding: 14px 0;
}
