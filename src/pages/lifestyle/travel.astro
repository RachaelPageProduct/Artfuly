---
import ArtfulyLayout from '../../layouts/ArtfulyLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('travel');
const sorted = allArticles
  .filter(a => a.data.published)
  .sort((a, b) => {
    if (!a.data.date && !b.data.date) return 0;
    if (!a.data.date) return 1;
    if (!b.data.date) return -1;
    return b.data.date.localeCompare(a.data.date);
  });
---

<ArtfulyLayout
  title="Travel — Away from the Race | Artfuly"
  description="How to work from anywhere. Rachael Page on location independence, digital nomad life, and working remotely across Europe."
>

  <!-- HERO: background video -->
  <section class="travel-hero">
    <video class="travel-hero__video" autoplay loop muted playsinline>
      <source src="/images/webflow-cdn/65b8dc00965457ed9e858550_IMG_6022-transcode.mp4" type="video/mp4" />
      <source src="/images/webflow-cdn/65b8dc00965457ed9e858550_IMG_6022-transcode.webm" type="video/webm" />
    </video>
    <div class="travel-hero__overlay"></div>
    <div class="travel-hero__text">
      <h1 class="travel-hero__title">Away from the Race</h1>
      <h2 class="travel-hero__subtitle">How to work from anywhere</h2>
    </div>
  </section>

  <!-- BIO + FORM — exact Webflow class/w-node structure so CSS grid fires correctly -->
  <section class="section-60">
    <div class="w-layout-blockcontainer container-1240 w-container">
      <div id="w-node-_9aaadddb-250d-e049-27e4-c763ed3d7169-c2eeca10" class="div-block-126">
        <img
          src="/images/webflow-cdn/65b8dcf0608be0bc9c489d4e_Untitled.jpg"
          loading="lazy"
          id="w-node-_55ebac6c-510d-88aa-b95e-b3a2dbe46c9c-c2eeca10"
          sizes="(max-width: 479px) 48vw, (max-width: 767px) 49vw, (max-width: 991px) 356px, 462px"
          alt="Rachael Page"
          srcset="/images/webflow-cdn/65b8dcf0608be0bc9c489d4e_Untitled-p-500.jpg 500w, /images/webflow-cdn/65b8dcf0608be0bc9c489d4e_Untitled.jpg 720w"
          class="image-46"
        />
      </div>
      <div id="w-node-_801ceaf6-0714-420b-d101-c3dd7df0b08f-c2eeca10">
        <h3 id="w-node-fcc12e2e-77d0-565e-9b2c-434413bde437-c2eeca10" class="t-h3">Do you want to work from anywhere?<br /></h3>
        <h4 class="t-h4">Hi, I'm Rachael and in 2016 I evolved...</h4>
        <div id="w-node-_15c0ad17-6902-c94c-fd04-e9ce485b403a-c2eeca10" class="t-paragraph">
          <p>In late 2016 I bought a van for myself and my cat, to work independent of any set location, working remotely and renting a place for the winter, or travelling to a warmer climate.</p>
          <p>So far I've spent 7 years working from anywhere - sometimes from a temporary home. I've found various ways to be location independent, and I blog about it here in an effort to help others break free.</p>
          <p><strong>Receive updates when I publish a new article:</strong></p>
        </div>
      </div>
      <div id="w-node-a178448b-35b8-c8cb-db4c-af98fa1532e1-c2eeca10">
        <!-- TODO: replace with Kit.com embed -->
        <div class="travel-form-placeholder">
          <p>Email sign-up form coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="section-61">
    <div class="w-layout-blockcontainer container-1241 w-container">
      <div id="w-node-a2914861-2d1d-0e8f-88ca-7755f1e39608-c2eeca10">
        <h2 id="w-node-_4d9a8892-b4f7-0b81-daee-d2c56301f289-c2eeca10" class="heading-86"><strong class="t-h2">How to Work from Anywhere</strong></h2>
        <h2 class="t-h5"><strong>#LocationIndependent #DigitalNomad #Make Money from anywhere</strong></h2>
      </div>
      <div id="w-node-_904553c2-e74d-4cee-fc67-0fb3621e4f94-c2eeca10" style="grid-column: 1 / -1;">
        <ul class="t-article-grid">
          {sorted.map(a => {
            const d = a.data;
            const img = d.thumbnailImage || d.heroImage || null;
            return (
              <li class="t-article-card">
                <a href={`/travel/${d.slug}/`} class="t-article-card__link">
                  {img && <img src={img} alt={d.title} class="t-article-card__img" loading="lazy" />}
                  {!img && <div class="t-article-card__img t-article-card__img--placeholder"></div>}
                  <div class="t-article-card__body">
                    <h3 class="t-article-card__title">{d.title}</h3>
                    {d.description && <p class="t-article-card__desc">{d.description}</p>}
                    <span class="t-article-card__cta">Read article →</span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </section>

  <!-- INSTAGRAM -->
  <section class="section-63" style="padding: 3rem 0 1rem;">
    <div class="w-layout-blockcontainer w-container">
      <h2 class="heading-86"><strong class="t-h2">Instagram — What's happening now</strong></h2>
    </div>
  </section>
  <section class="section-62" style="padding: 1rem 0 4rem;">
    <div class="w-layout-blockcontainer w-container">
      <!-- TODO: replace with Behold (behold.so) Instagram widget -->
      <div class="travel-instagram-placeholder">
        <p>Instagram feed — connect via <a href="https://behold.so" target="_blank" rel="noopener">Behold</a></p>
      </div>
    </div>
  </section>

</ArtfulyLayout>

<style>
.travel-hero {
  position: relative;
  width: 100%;
  height: 80vh;
  min-height: 480px;
  overflow: hidden;
  background: #222;
}
.travel-hero__video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.travel-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.38);
  z-index: 1;
}
.travel-hero__text {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rem;
}
.travel-hero__title {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(3rem, 7vw, 6rem);
  color: #fff !important;
  font-weight: 400;
  margin: 0 0 1rem;
  text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  line-height: 1.1;
}
.travel-hero__subtitle {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(0.9rem, 2vw, 1.2rem);
  color: #fff !important;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin: 0;
  text-shadow: 0 1px 6px rgba(0,0,0,0.5);
}

.travel-form-placeholder {
  background: #e8e8e8;
  border-radius: 4px;
  padding: 2rem;
  text-align: center;
  color: #666;
  font-size: 0.9rem;
  min-height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.travel-instagram-placeholder {
  background: #e8e8e8;
  border-radius: 4px;
  padding: 3rem 2rem;
  text-align: center;
  color: #666;
  font-size: 0.9rem;
}
.travel-instagram-placeholder a {
  color: #048ba2;
}

.t-article-grid {
  list-style: none;
  margin: 2rem 0 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.t-article-card { display: flex; }
.t-article-card__link {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid #e0eded;
  transition: box-shadow 0.18s;
  width: 100%;
}
.t-article-card__link:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.10); opacity: 1; }
.t-article-card__img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}
.t-article-card__img--placeholder { background: #e0eded; height: 180px; }
.t-article-card__body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.t-article-card__title {
  font-family: 'Montserrat', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #233030;
  margin: 0;
  line-height: 1.35;
}
.t-article-card__link:hover .t-article-card__title { color: #3ba89c; }
.t-article-card__desc {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  color: #555;
  line-height: 1.6;
  margin: 0;
  flex: 1;
}
.t-article-card__cta {
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: #3ba89c;
  margin-top: 4px;
}
@media (max-width: 991px) { .t-article-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 767px) { .t-article-grid { grid-template-columns: 1fr; } }
</style>
