---
import ArtfulyLayout from '../../layouts/ArtfulyLayout.astro';
---

<ArtfulyLayout
  title="Travel — Away from the Race | Artfuly"
  description="How to work from anywhere. Rachael Page on location independence, digital nomad life, and working remotely across Europe."
>

  <!-- Webflow shared CSS for content styling -->
  <link href="https://cdn.prod.website-files.com/5f6c775604d3a81512995971/css/artfuly.webflow.shared.791454ec3.min.css" rel="stylesheet" type="text/css" crossorigin="anonymous" />

  <!-- HERO: background video -->
  <section class="travel-hero">
    <video class="travel-hero__video" autoplay loop muted playsinline>
      <source src="https://cdn.prod.website-files.com/5f6c775604d3a81512995971/65b8dc00965457ed9e858550_IMG_6022-transcode.mp4" type="video/mp4" />
      <source src="https://cdn.prod.website-files.com/5f6c775604d3a81512995971/65b8dc00965457ed9e858550_IMG_6022-transcode.webm" type="video/webm" />
    </video>
    <div class="travel-hero__overlay"></div>
    <div class="travel-hero__text">
      <h1 class="travel-hero__title">Away from the Race</h1>
      <h2 class="travel-hero__subtitle">How to work from anywhere</h2>
    </div>
  </section>

  <!-- BIO + FORM -->
  <section class="section-60">
    <div class="w-layout-blockcontainer container-1240 w-container">
      <div id="w-node-bio-image" class="div-block-126">
        <img
          src="https://cdn.prod.website-files.com/5f6c775604d3a81512995971/65b8dcf0608be0bc9c489d4e_Untitled.jpg"
          loading="lazy"
          alt="Rachael Page"
          class="image-46"
          sizes="(max-width: 479px) 48vw, (max-width: 767px) 49vw, (max-width: 991px) 356px, 462px"
          srcset="https://cdn.prod.website-files.com/5f6c775604d3a81512995971/65b8dcf0608be0bc9c489d4e_Untitled-p-500.jpg 500w, https://cdn.prod.website-files.com/5f6c775604d3a81512995971/65b8dcf0608be0bc9c489d4e_Untitled.jpg 720w"
        />
      </div>
      <div id="w-node-bio-text">
        <h3 class="t-h3">Do you want to work from anywhere?<br /></h3>
        <h4 class="t-h4">Hi, I'm Rachael and in 2016 I evolved...</h4>
        <div class="t-paragraph">
          <p>In late 2016 I bought a van for myself and my cat, to work independent of any set location, working remotely and renting a place for the winter, or travelling to a warmer climate.</p>
          <p>So far I've spent 7 years working from anywhere - sometimes from a temporary home. I've found various ways to be location independent, and I blog about it here in an effort to help others break free.</p>
          <p><strong>Receive updates when I publish a new article:</strong></p>
        </div>
      </div>
      <div id="w-node-form-placeholder">
        <!-- TODO: replace with Kit.com embed -->
        <div class="travel-form-placeholder">
          <p>Email sign-up form coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="section-61">
    <div class="w-layout-blockcontainer container-1241 w-container">
      <div>
        <h2 class="heading-86"><strong class="t-h2">How to Work from Anywhere</strong></h2>
        <h2 class="t-h5"><strong>#LocationIndependent #DigitalNomad #Make Money from anywhere</strong></h2>
      </div>
      <div>
        <div class="w-dyn-list">
          <div role="list" class="w-dyn-items w-row">

            <div role="listitem" class="w-dyn-item w-col w-col-4">
              <span class="w-inline-block">
                <img loading="lazy" alt="Living with No Address"
                  src="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/6984434c59ccddb1acd8de18_Water%20house-p-500.webp"
                  srcset="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/6984434c59ccddb1acd8de18_Water%20house-p-500.webp 500w, https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/6984434c59ccddb1acd8de18_Water%20house-p-800.webp 800w"
                  sizes="(max-width: 479px) 44vw, (max-width: 767px) 46vw, 140px"
                />
                <h3 class="t-h3">Living with No Address</h3>
              </span>
            </div>

            <div role="listitem" class="w-dyn-item w-col w-col-4">
              <span class="w-inline-block">
                <img loading="lazy" alt="What it's really like in Germany for an immigrant or expat"
                  src="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/6824376dcef1c6f1ae58d395_Frame%20243.png"
                />
                <h3 class="t-h3">What it's really like in Germany for an immigrant or expat</h3>
              </span>
            </div>

            <div role="listitem" class="w-dyn-item w-col w-col-4">
              <span class="w-inline-block">
                <img loading="lazy" alt="How to buy a property with cash &amp; no mortgage &amp; be free"
                  src="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/6718c17dca8c1ca6341830e1_Screenshot%202024-10-23%20at%2011.27.09-p-500.png"
                  srcset="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/6718c17dca8c1ca6341830e1_Screenshot%202024-10-23%20at%2011.27.09-p-500.png 500w, https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/6718c17dca8c1ca6341830e1_Screenshot%202024-10-23%20at%2011.27.09-p-800.png 800w"
                  sizes="(max-width: 479px) 44vw, (max-width: 767px) 46vw, 140px"
                />
                <h3 class="t-h3">How to buy a property with cash &amp; no mortgage &amp; be free</h3>
              </span>
            </div>

            <div role="listitem" class="w-dyn-item w-col w-col-4">
              <span class="w-inline-block">
                <img loading="lazy" alt="Remote Working from Cefalù, Sicily"
                  src="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/65b680ae7b861e9ce1a4796d_Cefalu%20thumb-p-500.jpg"
                  srcset="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/65b680ae7b861e9ce1a4796d_Cefalu%20thumb-p-500.jpg 500w, https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/65b680ae7b861e9ce1a4796d_Cefalu%20thumb-p-800.jpg 800w"
                  sizes="(max-width: 479px) 44vw, (max-width: 767px) 46vw, 140px"
                />
                <h3 class="t-h3">Remote Working from Cefalù, Sicily</h3>
              </span>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INSTAGRAM PLACEHOLDER -->
  <section class="section-63" style="padding: 3rem 0 1rem;">
    <div class="w-layout-blockcontainer w-container">
      <h2 class="heading-86"><strong class="t-h2">Instagram — What's happening now</strong></h2>
    </div>
  </section>
  <section class="section-62" style="padding: 1rem 0 4rem;">
    <div class="w-layout-blockcontainer w-container">
      <!-- TODO: replace with Behold (behold.so) Instagram widget -->
      <!-- 1. Sign up at behold.so, connect your Instagram account -->
      <!-- 2. Create a widget and copy the embed code -->
      <!-- 3. Replace this placeholder with the <behold-widget feed-id="..."> tag -->
      <div class="travel-instagram-placeholder">
        <p>Instagram feed — connect via <a href="https://behold.so" target="_blank" rel="noopener">Behold</a></p>
      </div>
    </div>
  </section>

</ArtfulyLayout>

<style>
.travel-hero {
  position: relative;
  width: 100%;
  height: 80vh;
  min-height: 480px;
  overflow: hidden;
  background: #222;
}
.travel-hero__video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.travel-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.38);
  z-index: 1;
}
.travel-hero__text {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rem;
}
.travel-hero__title {
  font-family: 'Great Vibes', cursive;
  font-size: clamp(3rem, 7vw, 6rem);
  color: #fff !important;
  font-weight: 400;
  margin: 0 0 1rem;
  text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  line-height: 1.1;
}
.travel-hero__subtitle {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(0.9rem, 2vw, 1.2rem);
  color: #fff !important;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin: 0;
  text-shadow: 0 1px 6px rgba(0,0,0,0.5);
}

.travel-form-placeholder {
  background: #e8e8e8;
  border-radius: 4px;
  padding: 2rem;
  text-align: center;
  color: #666;
  font-size: 0.9rem;
  min-height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.travel-instagram-placeholder {
  background: #e8e8e8;
  border-radius: 4px;
  padding: 3rem 2rem;
  text-align: center;
  color: #666;
  font-size: 0.9rem;
}
.travel-instagram-placeholder a {
  color: #048ba2;
}
</style>
