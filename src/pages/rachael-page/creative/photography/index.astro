<BaseLayout title="Photography — Rachael Page" description="Photography by Rachael Page.">
  <style>
    .rp-photography { max-width: 1400px; margin: 2rem auto 4rem; padding: 0 2rem; }
    .rp-photography img { width: 100%; display: block; margin-bottom: 0.5rem; border-radius: 2px; }
    .rp-photography h2 { font-size: 2rem; font-weight: 700; color: #000000; text-align: center; margin-bottom: 2rem; }
  </style>

