---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const collections = [
  {
    slug: 'alhambra-haven',
    name: 'Alhambra Haven',
    thumb: '/images/patterns/alhambra-haven/mockups/duvet.jpeg',
    colourways: 5,
    tags: ['Wallpaper', 'Fabric', 'Ceramics'],
  },
  {
    slug: 'bloomsbury-hounds',
    name: 'Bloomsbury Hounds',
    thumb: '/images/patterns/bloomsbury-hounds/Mockups/Tiny pattern blue.jpeg',
    colourways: 7,
    tags: ['Wallpaper', 'Fabric', 'Home Accessories'],
  },
  {
    slug: 'shoreline-drift',
    name: 'Shoreline Drift',
    thumb: '/images/patterns/shoreline-drift/mockups/22235901 (6).jpeg',
    colourways: 5,
    tags: ['Wallpaper', 'Fabric', 'Home Accessories'],
  },
  {
    slug: 'verdant',
    name: 'Verdant',
    thumb: '/images/patterns/verdant/mockups/22236462.jpeg',
    colourways: 5,
    tags: ['Wallpaper', 'Fabric', 'Home Accessories'],
  },
  {
    slug: 'pebble',
    name: 'Pebble',
    thumb: '/images/patterns/pebble/mockups/Bathroom mockup 1.jpeg',
    colourways: 2,
    tags: ['Wallpaper', 'Fabric', 'Home Accessories'],
  },
  {
    slug: 'labyrinth',
    name: 'Labyrinth',
    thumb: '/images/patterns/labyrinth/21268327.jpeg',
    colourways: 5,
    tags: ['Upholstery', 'Wallpaper', 'Home Accessories'],
  },
  {
    slug: 'good-dogs',
    name: 'Good Dogs',
    thumb: '/images/patterns/good-dogs/mockup/Dog wallpaper mockup 1.jpeg',
    colourways: 1,
    tags: ['Wallpaper', 'Fabric', 'Home Accessories'],
  },
];
---

<BaseLayout
  title="Surface Pattern Design — Rachael Page"
  description="Original surface pattern design collections by Rachael Page. Available for wallpaper, fabric, ceramics, and home accessories licensing."
>

  <div class="spd-index-page">

    <header class="spd-index-header">
      <h1>Surface Pattern Design</h1>
      <p>Original collections available for wallpaper, fabric, ceramics &amp; home accessories licensing.</p>
    </header>

    <div class="spd-collections-grid">
      {collections.map(c => (
        <a href={`/rachael-page/creative/surface-pattern-design/${c.slug}`} class="spd-collection-card">
          <div class="spd-collection-img-wrap">
            <img src={c.thumb} alt={c.name} loading="lazy" />
          </div>
          <div class="spd-collection-info">
            <p class="spd-collection-card-name">{c.name}</p>
            <p class="spd-collection-card-meta">{c.colourways} colourways &middot; {c.tags.join(' · ')}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="spd-index-cta">
      <h2 class="spd-licensing-title">Interested in licensing a collection?</h2>
    </div>

  </div>

</BaseLayout>

<style>
.spd-index-page {
  max-width: 1200px;
  margin: 0 auto;
  padding: 3rem 2rem 5rem;
}

.spd-index-header {
  text-align: center;
  margin-bottom: 3rem;
}
.spd-index-header h1 {
  font-family: 'Parisienne', cursive;
  font-weight: 400;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  color: #048ba2 !important;
  letter-spacing: 0;
  margin-bottom: 0.6rem;
}
.spd-index-header p {
  font-size: 1rem;
  color: var(--color-text-muted);
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.6;
}

.spd-collections-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 2rem;
}

.spd-collection-card {
  display: block;
  text-decoration: none;
  color: inherit;
  border-radius: 4px;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.spd-collection-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.1);
}

.spd-collection-img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f5f5f2;
}
.spd-collection-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.spd-collection-card:hover .spd-collection-img-wrap img {
  transform: scale(1.03);
}

.spd-collection-info {
  padding: 0.85rem 0 0;
}
.spd-collection-card-name {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-dark);
  margin: 0 0 0.2rem;
}
.spd-collection-card-meta {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  margin: 0;
}

.spd-index-cta {
  text-align: center;
  margin-top: 4rem;
  padding-top: 3rem;
  border-top: 1px solid var(--color-border);
}
.spd-licensing-title {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-dark);
  margin: 0;
  letter-spacing: -0.01em;
}
.btn-accent {
  background: var(--color-accent);
  color: #fff;
  padding: 0.75rem 1.75rem;
  border-radius: 4px;
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  transition: opacity 0.15s;
  display: inline-block;
}
.btn-accent:hover { opacity: 0.85; }

@media (max-width: 600px) {
  .spd-collections-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
}
</style>
