---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const colourways = [
  { name: 'Artboard 2',          file: 'Artboard 2.png' },
  { name: 'Artboard 3',          file: 'Artboard 3.png' },
  { name: 'Coastal Leaf — Beige', file: 'Coastal_Leaf_Design_-_Beige.jpg' },
  { name: 'Ripple Dots — Desaturated Blues', file: 'Coastal_Ripple_Dots_Small_-_Desaturated_Blues.jpg' },
];

const mockups = [
  { file: 'mockups/22235901 (6).jpeg',  caption: 'Wallpaper — Bedroom' },
  { file: 'mockups/22235901 (7).jpeg',  caption: 'Wallpaper — Bedroom close-up' },
  { file: 'mockups/22235901 (9).jpeg',  caption: 'Fabric — Curtains' },
  { file: 'mockups/22235901 (5).jpeg',  caption: 'Fabric — Bed linen set' },
  { file: 'mockups/22235901 (4).jpeg',  caption: 'Fabric — Cocktail napkins' },
  { file: 'mockups/22235901 (3).jpeg',  caption: 'Fabric — Throw' },
  { file: 'mockups/22235901.jpeg',      caption: 'Fabric — close-up' },
  { file: 'mockups/Blue stairway.jpeg', caption: 'Wallpaper — Stairway' },
  { file: 'mockups/Desaturated blue pillow mockup.jpeg', caption: 'Fabric — Pillow, desaturated blue' },
];
---

<BaseLayout title="Shoreline Drift — Surface Pattern Collection by Rachael Page" description="Coastal botanical patterns in soft aqua, seafoam and sandy neutrals. Shoreline Drift wallpaper and fabric collection available for licensing.">

  <!-- COLLECTION HERO -->
  <section class="spd-hero">
    <div class="spd-hero-text">
      <p class="spd-collection-label">Surface Pattern Collection</p>
      <h1 class="spd-collection-name">Shoreline Drift</h1>
      <p class="spd-collection-desc">
        Easy to combine coastal designs for bedrooms and hotel rooms.
      </p>
      <div class="spd-meta">
        <span>5 colourways</span>
        <span>Straight repeat</span>
        <span>Wallpaper · Fabric · Home Accessories</span>
      </div>
      <a href="mailto:artfulydesign@gmail.com?subject=Licensing%20enquiry%20—%20Shoreline%20Drift" class="spd-cta">
        Enquire about licensing
      </a>
    </div>
    <div class="spd-hero-image">
      <img src="/images/patterns/shoreline-drift/mockups/22235901 (6).jpeg" alt="Shoreline Drift — wallpaper in bedroom" />
    </div>
  </section>

  <!-- COLOURWAYS GRID -->
  <section class="spd-colourways">
    <div class="spd-colourways-inner">
      <h2 class="spd-section-label">Colourways</h2>
      <div class="spd-grid">
        {colourways.map(c => (
          <div class="spd-swatch">
            <img src={`/images/patterns/shoreline-drift/${c.file}`} alt={`Shoreline Drift — ${c.name}`} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MOCKUPS / IN CONTEXT -->
  <section class="spd-mockups">
    <div class="spd-mockups-inner">
      <h2 class="spd-section-label">In Context</h2>
      <div class="spd-mockups-grid">
        {mockups.map(m => (
          <figure class="spd-mockup-item">
            <img src={`/images/patterns/shoreline-drift/${m.file}`} alt={m.caption} loading="lazy" />
            <figcaption>{m.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- LICENSING CTA -->
  <section class="spd-licensing">
    <div class="spd-licensing-inner">
      <h2 class="spd-licensing-title">Interested in licensing this collection?</h2>
    </div>
  </section>

  <!-- BACK TO ALL COLLECTIONS -->
  <div class="spd-back">
    <a href="/rachael-page/creative/surface-pattern-design/">← All Collections</a>
  </div>

</BaseLayout>
