---
// Rachael Page portfolio homepage — built from NoCodeExport HTML + Webflow CSS
import RPNav from '../../components/RPNav.astro';
import { getCollection } from 'astro:content';
const allArticles = await getCollection('articles');
const featuredArticles = allArticles
  .filter((a: any) => a.data.featuredPortfolio === true && a.data.published === true)
  .sort((a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const articleCols = featuredArticles.length === 4 ? 2 : 3;
