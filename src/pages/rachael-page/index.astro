---

<BaseLayout title="Rachael Page — Product Designer" description="Product designer with 20+ years experience at tech startups and ad agencies. Currently building apps with AI.">

  <!-- 1. HERO — light teal bg, Rachael photo right, text left -->
  <section class="rp-hero" style="background-color:#ceeaeb; background-image:url('https://cdn.prod.website-files.com/5f6c775604d3a81512995971/680a2b65f811643bd4251da9_Dreamwave-Photo%20extended.png'); background-position: right bottom; background-repeat: no-repeat; background-size: auto 100%; min-height:595px;">
    <div class="rp-hero-inner">
      <h1 class="rp-heading-analytical">Analytical</h1>
      <h1 class="rp-heading-creative">+ Creative</h1>
    </div>
  </section>

  <!-- 2. TOOL ICONS STRIP -->
  <section class="rp-icons-strip">
    <div class="rp-icons-inner">
      {toolIcons.map(src => <img src={src} alt="" loading="lazy" class="rp-tool-icon" />)}
    </div>
  </section>

  <!-- 3. ABOUT / BIO -->
  <section class="rp-about" id="about">
    <div class="rp-about-inner">
      <p class="rp-bio">I'm Rachael, a Product Design Engineering graduate, with over 20 years of experience at tech startups & ad agencies, creating & delivering successful products based on thorough user research & testing. Currently using Claude Code to design & build — fast!</p>
      <p class="rp-bio">I recently completed my PWA app <a href="/project/ticklists-app" class="rp-inline-link">TickLists</a>, and before that was Principal Designer for <a href="/project/terra-app" class="rp-inline-link">Terra Listens</a>. Currently considering new opportunities — get in touch!</p>
      <div class="rp-about-actions">
        <a href="mailto:artfulydesign@gmail.com?subject=Enquiry%20from%20your%20portfolio" class="btn btn-black">Email me</a>
        <a href="mailto:artfulydesign@gmail.com?subject=Enquiry%20from%20your%20portfolio" class="btn btn-white">Copy Email</a>
      </div>
    </div>
  </section>

  <!-- 4. CLIENT LOGOS -->
  <section class="rp-client-logos">
    <img src="https://cdn.prod.website-files.com/5f6c775604d3a81512995971/6544e287b8bf3aa40ebdb875_logos.png" alt="Clients: ING, AMCOR, KPMG, PWC, Sydney University, Ogilvy and others" loading="lazy" class="rp-logos-img" />
  </section>

  <!-- 5. FEATURED WORK -->
  <section class="rp-work" id="work">
    <div class="rp-work-inner">
      <div class="rp-work-header">
        <h2 class="rp-work-heading">Featured Work</h2>
        <p class="rp-work-subheading">...or select a category</p>
        <div class="rp-cat-pills">
          {workCategories.map(cat => (
            <a href={`/work/${cat.slug}`} class="rp-cat-pill">{cat.label}</a>
          ))}
          <a href="/work/all" class="rp-cat-pill rp-cat-pill-all">All Work →</a>
        </div>
      </div>

      <!-- Featured hero project: TickLists -->
      <a href="/project/ticklists-app" class="rp-work-featured">
        <div class="rp-work-featured-img">
          <img src="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/69cb52e15e1262503966edfa_Frame%204.png" alt="TickLists App" loading="lazy" />
        </div>
        <div class="rp-work-featured-info">
          <h3>Ticklists App</h3>
          <p>PWA (Progressive Web App) for shared repetitive shopping & routines. Gives items their own section in the list (Dairy, Fruit &amp; Veg etc.) so the list sorts itself into the right order. Never retype your list again.</p>
          <span class="rp-arrow">→</span>
        </div>
      </a>

      <!-- Other projects -->
      <div class="rp-work-others-grid">
        <a href="/project/terra-app" class="rp-work-card">
          <img src="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/68a5e7984df7a15a836e8c16_Animation%20full%20width%20terra%20app.gif" alt="Terra Listens Native Apps" loading="lazy" />
          <div class="rp-work-card-info">
            <h3>Terra Listens Native Apps</h3>
            <p>Streaming nature sounds from gardens & global birding hotspots. Identifies birds by birdsong via a smart-garden device.</p>
            <span class="rp-arrow">→</span>
          </div>
        </a>
        <a href="/project/mcdonalds-monopoly-web-app" class="rp-work-card">
          <img src="https://cdn.prod.website-files.com/5f6c7756eae6eb60a54c6c38/68b708cebd505968fe886419_Showreel%20(2).gif" alt="McDonalds Monopoly Web-App" loading="lazy" />
          <div class="rp-work-card-info">
            <h3>McDonalds Monopoly Web-App</h3>
            <p>Fun year-long project designing the mobile-first game interface for the McDonald's Monopoly promotion.</p>
            <span class="rp-arrow">→</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <div class="rp-page">

    <!-- 6. SKILLS -->
    <section class="rp-section" id="skills">
      <h2 class="rp-section-heading">Skills</h2>
      <div class="rp-skills-grid">
        {Object.entries(skills).map(([heading, items]) => (
          <div class="rp-skill-col">
            <h3 class="rp-skill-heading">{heading}</h3>
            <ul>{items.map(item => <li>{item}</li>)}</ul>
          </div>
        ))}
      </div>
    </section>

    <!-- 7. EXPERIENCE -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Experience</h2>
      <div class="rp-timeline">
        {experience.map(job => (
          <div class="rp-timeline-item">
            <div class="rp-timeline-left">
              <div class="rp-timeline-dates">{job.dates}</div>
              <div class="rp-timeline-companies">{job.companies}</div>
            </div>
            <div class="rp-timeline-body">
              <div class="rp-timeline-title">{job.title}</div>
              <p class="rp-timeline-desc">{job.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 8. QUALIFICATIONS -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Qualifications</h2>
      <ul class="rp-quals">
        <li><strong>Award School</strong><span>Australian Writers &amp; Art Directors</span></li>
        <li><strong>Adobe Creative Suite</strong><span>Hypermouse</span></li>
        <li><strong>Bachelor of Engineering (Honours) in Product Design</strong><span>Loughborough University, UK</span></li>
      </ul>
    </section>

    <!-- 9. WHAT MAKES ME UNIQUE -->
    <section class="rp-section rp-unique-section">
      <div class="rp-unique-inner">
        <div class="rp-unique-photo">
          <img src="https://cdn.prod.website-files.com/5f6c775604d3a81512995971/680a362825eac4ec06647a63_Dreamwave-Photo%20(1c)%20ful%20length%20v2.png" alt="Rachael Page" loading="lazy" />
        </div>
        <div class="rp-unique-content">
          <h2 class="rp-section-heading">What makes me unique</h2>
          <ul class="rp-unique-list">
            {uniquePoints.map(p => (
              <li><strong>{p.heading}:</strong> {p.text}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- 10. TESTIMONIALS -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Testimonials</h2>
      <p class="rp-refs-note">References available on request</p>
      <div class="rp-testimonials">
        {testimonials.map(t => (
          <div class="rp-testimonial">
            <div class="rp-stars">★★★★★</div>
            <blockquote>"{t.quote}"</blockquote>
            <cite><strong>{t.name}</strong><br/>{t.location}</cite>
          </div>
        ))}
      </div>
    </section>

    <!-- 11. BOOKS & ARTICLES -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Books &amp; Articles</h2>
      <p class="rp-refs-note">Published Books and my Articles published here and on other websites</p>
      <div class="rp-articles-grid">
        {articles.map(a => (
          <a href={a.url} class="rp-article-card">
            <img src={a.image} alt={a.title} loading="lazy" />
            <p>{a.title}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- 12. PHOTOGRAPHY -->
    <section class="rp-section">
      <h2 class="rp-section-heading">My photography &amp; me</h2>
      <div class="rp-photo-grid">
        {photos.map((src, i) => <img src={src} alt="" loading="lazy" />)}
      </div>
    </section>

  </div>

</BaseLayout>
