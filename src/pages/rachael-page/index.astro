  <script>
    // Active nav highlighting via IntersectionObserver (homepage only)
    const navLinks = {
      'About':   document.querySelector('#rp-nav-list a[href*="#About"]'),
      'Work':    document.querySelector('#rp-nav-list a[href*="/rachael-page/work/all"]'),
      'contact': document.querySelector('#rp-nav-list a[href*="#contact"]'),
    };
    const sectionIds = ['About', 'Work', 'Skills', 'contact'];
    const setActive = (id) => {
      Object.values(navLinks).forEach(a => a && a.classList.remove('rp-active'));
      // Map section -> nav link
      if (id === 'About' && navLinks['About']) navLinks['About'].classList.add('rp-active');
      if ((id === 'Work' || id === 'Skills') && navLinks['Work']) navLinks['Work'].classList.add('rp-active');
      if (id === 'contact' && navLinks['contact']) navLinks['contact'].classList.add('rp-active');
    };
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); });
    }, { rootMargin: '-70px 0px -50% 0px', threshold: 0 });
    sectionIds.forEach(id => { const el = document.getElementById(id); if (el) io.observe(el); });


  </script>

