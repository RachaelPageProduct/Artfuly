---

<BaseLayout title="Rachael Page — Product Designer" description="Product designer with 20+ years experience at tech startups and ad agencies. Currently building apps with AI.">

  <!-- HERO -->
  <section class="rp-hero">
    <div class="rp-hero-inner">
      <div class="rp-hero-left">
        <h1 class="rp-hero-heading">Analytical<br/>+ Creative</h1>
        <p class="rp-hero-bio">Graduate in Product Design Engineering with 20+ years at tech startups and ad agencies, creating products through user research and testing. Recently completed TickLists PWA app; previously Principal Designer for Terra Listens. Seeking new opportunities.</p>
        <div class="rp-hero-actions">
          <a href="mailto:artfulydesign@gmail.com?subject=Enquiry%20from%20your%20portfolio" class="btn btn-black">Email me</a>
          <a href="https://www.linkedin.com/in/rachaelpage" target="_blank" rel="noopener" class="btn btn-white">LinkedIn</a>
        </div>
      </div>
      <div class="rp-icon-grid">
        {iconGrid.map(src => (
          <img src={src} alt="" loading="lazy" class="rp-icon" />
        ))}
      </div>
    </div>
  </section>

  <div class="rp-page">

    <!-- FEATURED WORK -->
    <section class="rp-section" id="work">
      <h2 class="rp-section-heading">Featured Work</h2>
      <div class="rp-projects-grid">
        {featuredProjects.map(proj => (
          <a href={`/project/${proj.slug}`} class="rp-project-card">
            {proj.gif && <img src={proj.gif} alt={proj.title} loading="lazy" class="rp-project-img" />}
            <div class="rp-project-info">
              <h3>{proj.title}</h3>
              <p>{proj.description}</p>
              <span class="rp-arrow">→</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Work category filters -->
      <div class="rp-category-filters">
        {workCategories.map(cat => (
          <a href={`/work/${cat.slug}`} class="rp-cat-link">{cat.label}</a>
        ))}
        <a href="/work/all" class="rp-cat-link rp-cat-all">All Work →</a>
      </div>
    </section>

    <!-- SKILLS -->
    <section class="rp-section" id="skills">
      <h2 class="rp-section-heading">Skills &amp; Experience</h2>
      <div class="rp-skills-grid">
        {Object.entries(skills).map(([heading, items]) => (
          <div class="rp-skill-col">
            <h3 class="rp-skill-heading">{heading}</h3>
            <ul>
              {items.map(item => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section class="rp-section" id="about">
      <h2 class="rp-section-heading">Experience</h2>
      <div class="rp-timeline">
        {experience.map(job => (
          <div class="rp-timeline-item">
            <div class="rp-timeline-dates">{job.dates}</div>
            <div class="rp-timeline-body">
              <div class="rp-timeline-company">{job.companies}</div>
              <div class="rp-timeline-title">{job.title}</div>
              <p class="rp-timeline-desc">{job.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- QUALIFICATIONS -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Qualifications</h2>
      <ul class="rp-quals">
        <li><strong>Award School</strong> — Australian Writers &amp; Art Directors</li>
        <li><strong>Adobe Creative Suite</strong> — Hypermouse</li>
        <li><strong>Bachelor of Engineering (Honours) in Product Design</strong> — Loughborough University, UK</li>
      </ul>
    </section>

    <!-- TESTIMONIALS -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Testimonials</h2>
      <div class="rp-testimonials">
        {testimonials.map(t => (
          <div class="rp-testimonial">
            <div class="rp-stars">
              {'★★★★★'}
            </div>
            <blockquote>"{t.quote}"</blockquote>
            <cite>
              <strong>{t.name}</strong><br/>
              {t.location}
            </cite>
          </div>
        ))}
      </div>
    </section>

    <!-- BOOKS & ARTICLES -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Books &amp; Articles</h2>
      <div class="rp-articles-grid">
        {articles.map(a => (
          <a href={a.url} class="rp-article-card">
            <img src={a.image} alt={a.title} loading="lazy" />
            <p>{a.title}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- PHOTOGRAPHY -->
    <section class="rp-section">
      <h2 class="rp-section-heading">Photography</h2>
      <div class="rp-photo-grid">
        {photos.map((src, i) => (
          <img src={src} alt={`Photography ${i + 1}`} loading="lazy" />
        ))}
      </div>
    </section>

  </div><!-- end rp-page -->

</BaseLayout>
