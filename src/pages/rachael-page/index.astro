  { dates: 'Sep 2021 – Dec 2022', companies: 'KPMG & PWC, London', title: 'Freelance UX Researcher & UI Designer', description: 'Via Play Studio — user researcher for KPMG UK and PWC UK.' },
  { dates: 'Jan 2012 – 2020', companies: 'Artfuly, Online', title: 'Founder, Head of UX & Product', description: 'Global art marketplace enabling artists to market and sell artworks with door-to-door delivery.' },
  { dates: 'Nov 2016 – Jul 2017', companies: 'Amcor, Zurich', title: 'Senior UX Consultant', description: 'Redesigned Amcor.com products section — stakeholder interviews, user research, product database design, prototypes and visual design, via Tzu&Co.' },
  { dates: 'Oct 2015 – Jun 2016', companies: 'Sydney University, Australia', title: 'Lead UX (Contract)', description: 'User research and design for high-profile university project (student income $760M AUD in 2014).' },
  { dates: '2004 – 2012', companies: 'Several top Ad Agencies, Australia', title: 'Senior UI/UX Designer (Contract)', description: 'Mobile app, podium touchscreen, and responsive website design work.' },
