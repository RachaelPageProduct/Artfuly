---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.data.slug }, props: { project: p, allProjects: projects } }));
}

const { project, allProjects } = Astro.props;
const d = project.data;

// Look up next project title from slug
const nextProjectEntry = d.nextProject
  ? allProjects.find((p: any) => p.data.slug === d.nextProject)
  : null;
const nextProjectTitle = nextProjectEntry?.data?.title ?? d.nextProject ?? '';

// Map CSV category slugs to display names
const catLabels: Record<string, string> = {
  'apps': 'Native Apps & PWAs', 'ia': 'IA & Database Design', 'marketing': 'Marketing & SEO',
  'strategy': 'Strategy', 'teaching-design': 'Teaching Design', 'ui-design': 'UI Design',
  'ux-design': 'UX Design', 'product-design': 'Product Design', 'development': 'Development',
  'conversion-funnels': 'Conversion Funnels', 'graphic-design': 'Graphic Design',
  'motion-design': 'Motion Design', 'motion-design-animation': 'Motion Design',
  'pwa': 'Native Apps & PWAs', 'user-research': 'User Research & Testing',
  'user-research-testing': 'User Research & Testing', 'seo': 'Marketing & SEO',
  'responsive-websites': 'UX Design', 'surface-pattern-design': 'Graphic Design',
  'all': 'All Work',
};
const catUrl: Record<string, string> = {
  'apps': 'native-apps-pwas', 'ia': 'ia-database-design', 'marketing': 'marketing-seo',
  'strategy': 'strategy', 'teaching-design': 'development', 'ui-design': 'ui-design',
  'ux-design': 'ux-design', 'product-design': 'product-design', 'development': 'development',
  'conversion-funnels': 'conversion-funnels', 'graphic-design': 'graphic-design',
  'motion-design': 'motion-design', 'motion-design-animation': 'motion-design',
  'pwa': 'native-apps-pwas', 'user-research': 'user-research-testing',
  'user-research-testing': 'user-research-testing', 'seo': 'marketing-seo',
  'responsive-websites': 'ux-design', 'surface-pattern-design': 'graphic-design',
};

// Browse by category pills (bottom of page)
const browseCategories = [
  { label: 'All Work', slug: 'all' },
  { label: 'Product Design', slug: 'product-design' },
  { label: 'UX Design', slug: 'ux-design' },
  { label: 'User Research & Testing', slug: 'user-research-testing' },
  { label: 'UI Design', slug: 'ui-design' },
  { label: 'Strategy', slug: 'strategy' },
  { label: 'IA & Database Design', slug: 'ia-database-design' },
  { label: 'Native Apps & PWAs', slug: 'native-apps-pwas' },
  { label: 'Marketing & SEO', slug: 'marketing-seo' },
  { label: 'Conversion Funnels', slug: 'conversion-funnels' },
  { label: 'Development', slug: 'development' },
];

// Button helper — only render if both label and link exist
const buttons = [
  { label: d.button1, href: d.link1, style: 'white-on-black' },
  { label: d.button2, href: d.link2, style: 'black-on-white' },
  { label: d.button3, href: d.link3, style: 'black-on-white' },
  { label: d.button4, href: d.link4, style: 'black-on-white' },
].filter(b => b.label && b.href);
---

<BaseLayout title={`${d.title} — Rachael Page`} description={d.summary}>
  <link rel="stylesheet" href="/styles/webflow.css" slot="head" />
  {d.slug === 'ticklists-app' && (
    <Fragment slot="head" set:html={`<style>
      .w-richtext figure.w-richtext-figure-type-image:not(:has(img[src*="Spreadsheet"])):not(:has(img[src*="wireframe"])):not(:has(img[src*="design-directions"])) { display: block !important; max-width: 25% !important; margin-left: auto !important; margin-right: auto !important; }
      .w-richtext figure.w-richtext-figure-type-image:not(:has(img[src*="Spreadsheet"])):not(:has(img[src*="wireframe"])):not(:has(img[src*="design-directions"])) > div { display: block !important; max-width: 100%; }
      .w-richtext figure.w-richtext-figure-type-image:not(:has(img[src*="Spreadsheet"])):not(:has(img[src*="wireframe"])):not(:has(img[src*="design-directions"])) img { width: 100% !important; height: auto !important; }
    </style>`} />
  )}

  <!-- PAGE TRANSITION OVERLAY (Dennis Snellenberg effect) -->
  <div class="dennis-overlay" id="dennisOverlay" aria-hidden="true">
    <div class="dennis-title" id="dennisTitleText">{d.title}</div>
  </div>

  <!-- PROJECT TITLE -->
  <section class="r-showcase-section">
    <div class="w-layout-blockcontainer w-container">
      <h1 class="r-1-showcase-page">{d.title}</h1>
    </div>
  </section>

  <!-- ROLE / TEAM / DATE & TOOLS -->
  {(d.role || d.team || d.date) && (
    <section class="r-project-details">
      <div class="w-layout-blockcontainer container-940-pad-20lr w-container">
        <div class="div-block-102">
          <div><div class="r-body bold-small-caps grey">MY Role(s)</div></div>
          <div><div class="r-body bold-small-caps grey">the Team</div></div>
          <div><div class="r-body bold-small-caps grey">Date &amp; tools</div></div>
          <div><div class="r-body small" set:html={d.role?.replace(/\n/g,'<br>')} /></div>
          <div><div class="r-body small" set:html={d.team?.replace(/\n/g,'<br>')} /></div>
          <div>
            <div class="r-body small">{d.date}</div>
            <div class="r-body small">{d.tools}</div>
          </div>
        </div>
        <div class="spacer _32"></div>
      </div>
    </section>
  )}

  <!-- IMPACT (moved up: proof line goes right after ownership block, before the intro/disclaimer/personas wall) -->
  {d.impact && (
    <section class="r-showcase-section">
      <div class="w-layout-blockcontainer container-940-pad-20lr w-container">
        <div><h3>Impact</h3><p>{d.impact}</p></div>
      </div>
    </section>
  )}

  <!-- LOTTIE / HEADER IMAGE -->
  {d.lottieUrl && (
    <section class="r-project-header-lottie">
      <div>
        <div id="lottie-animation" style="width:100%;height:auto;"></div>
        <script define:vars={{ lottieUrl: d.lottieUrl }}>
          function initLottie() {
            if (typeof lottie !== 'undefined') {
              lottie.loadAnimation({ container: document.getElementById('lottie-animation'), renderer: 'svg', loop: true, autoplay: true, path: lottieUrl });
            } else {
              setTimeout(initLottie, 100);
            }
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initLottie);
          } else {
            initLottie();
          }
        </script>
      </div>
    </section>
  )}
  {!d.lottieUrl && (d.heroVideo || d.headerImage) && (
    <section class="r-project-header-lottie">
      {d.heroVideo ? (
        <video src={d.heroVideo} autoplay loop muted playsinline style="width:100%;height:auto;display:block;" />
      ) : (
        <img src={d.headerImage} alt={d.title} style="width:100%;height:auto;display:block;" loading="lazy" />
      )}
    </section>
  )}

  <!-- SKILLS & DELIVERABLES PILLS -->
  {d.workCategories?.length > 0 && (
    <section class="r-showcase-section">
      <div class="w-layout-blockcontainer container-940-pad-20lr w-container">
        <section class="r-pills">
          <div class="div-block-156">
            <div class="r-body bold-small-caps grey no-line">SKILLS &amp;<br/>DELIVERABLES</div>
          </div>
          <div class="w-layout-blockcontainer r-container-pills w-container">
            <div class="w-dyn-items" role="list">
              {d.workCategories.map((cat: string) => (
                <div role="listitem" class="collection-item-12 w-dyn-item">
                  <a href={`/rachael-page/work/${catUrl[cat] || cat}/`} class="r-work-category-pill w-button">
                    {catLabels[cat] || cat.replace(/-/g,' ').replace(/\b\w/g,(c:string)=>c.toUpperCase())}
                  </a>
                </div>
              ))}
            </div>
          </div>
        </section>
      </div>
    </section>
  )}

  <!-- INTRODUCTION -->
  {d.introduction && (
    <div class="w-layout-blockcontainer r-showcase-container w-container">
      <div>
        <div class="rich-text-block-5 w-richtext" set:html={d.introduction} />
      </div>
    </div>
  )}

  <!-- TOOL VIDEO EMBED (Bunny inline embed) -->
  {d.toolVideoEmbed && (
    <section class="section-77">
      <div class="w-layout-blockcontainer r-showcase-container w-container">
        <div class="div-block-153" set:html={d.toolVideoEmbed} />
      </div>
    </section>
  )}

  <!-- DESIGN TALKTHROUGH VIDEO -->
  {d.designTalkthrough && (
    <section class="design-talkthrough">
      <div class="w-layout-blockcontainer container-940-pad-20lr w-container">
        <div><h2>Design Talkthrough</h2></div>
        <div class="w-video w-embed">
          <iframe src={d.designTalkthrough} style="width:100%;aspect-ratio:16/9;border:none;" allowfullscreen loading="lazy" />
        </div>
      </div>
    </section>
  )}

  <!-- CLICKABLE PROTOTYPE EMBED -->
  {d.prototypeEmbed && (
    <section class="r-showcase-section">
      <div class="w-layout-blockcontainer container-940-pad-20lr w-container">
        <div class="rich-text-block-5 w-richtext" set:html={d.prototypeEmbed} />
      </div>
    </section>
  )}

  <!-- PROJECT IN DETAIL -->
  {d.projectInDetail && (
    <section class="r-showcase-section">
      <div class="w-layout-blockcontainer r-showcase-container w-container">
        <div class="rich-text-block-5 w-richtext" set:html={d.projectInDetail} />
      </div>
    </section>
  )}

  <!-- DESIGN HIGHLIGHTS -->
  {d.designHighlights && (
    <section class="r-showcase-section">
      <div class="w-layout-blockcontainer container-940-pad-20lr w-container">
        <div class="w-richtext" set:html={d.designHighlights} />
      </div>
    </section>
  )}

  <!-- BUTTONS -->
  {buttons.length > 0 && (
    <section class="r-buttons-to-detail">
      <div class="w-layout-blockcontainer container-940-pad-20lr w-container">
        <div class="div-block-154"><h2>Links &amp; More Info</h2></div>
        <div class="div-block-106">
          {buttons.map(b => (
            <a href={b.href} target="_blank" rel="noopener"
               class={b.style === 'white-on-black' ? 'r-button-white-on-black w-button' : 'r-button-black-on-white w-button'}>
              {b.label}
            </a>
          ))}
        </div>
        <div class="spacer _16"></div>
      </div>
    </section>
  )}

  <!-- NEXT PROJECT + BROWSE CATEGORIES -->
  <section class="next-project-strip">
    {d.nextProject && (
      <a href={`/rachael-page/project/${d.nextProject}/`} class="next-project-link">
        <span class="next-project-label">Next project</span>
        <span class="next-project-title">{nextProjectTitle} →</span>
      </a>
    )}
    <div class="browse-categories">
      <span class="browse-label">…or select a category</span>
      <div class="browse-pills">
        {browseCategories.map(cat => (
          <a href={`/rachael-page/work/${cat.slug}/`} class="browse-pill">{cat.label}</a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Next project strip + browse ── */
.next-project-strip {
  background: #000;
  padding: 56px 48px 48px;
}
.next-project-link {
  display: flex;
  align-items: center;
  gap: 32px;
  text-decoration: none;
  max-width: 1100px;
  margin: 0 auto;
}
.next-project-link:hover { opacity: 0.8; }
.next-project-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  white-space: nowrap;
}
.next-project-title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(1.6rem, 3.5vw, 2.8rem);
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

/* ── Browse categories ── */
.browse-categories {
  display: flex;
  align-items: flex-start;
  gap: 32px;
  margin-top: 48px;
  padding-top: 40px;
  border-top: 1px solid rgba(255,255,255,0.15);
  max-width: 1100px;
  margin-left: auto;
  margin-right: auto;
}
.browse-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  white-space: nowrap;
  padding-top: 6px;
  flex-shrink: 0;
}
.browse-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.browse-pill {
  font-family: 'Montserrat', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  color: #fff;
  border: 1.5px solid rgba(255,255,255,0.5);
  border-radius: 40px;
  padding: 6px 18px;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
}
.browse-pill:hover {
  background: #fff;
  color: #000;
  border-color: #fff;
  opacity: 1;
}

/* ── Dennis Snellenberg entrance effect ──────────────────
   Phase 1: Full-screen dark overlay with centred title
   Phase 2: Bottom edge curves upward into a dome at top
   Phase 3: Overlay disappears
   ────────────────────────────────────────────────────── */

.dennis-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  /* Phase 1: hold for 400ms, then phase 2 arch (600ms), then phase 3 fade (200ms) */
  animation: dennisArch 1.2s cubic-bezier(0.76, 0, 0.24, 1) 0.4s forwards;
}

.dennis-title {
  font-family: 'Montserrat', sans-serif;
  font-size: clamp(22px, 4vw, 52px);
  font-weight: 800;
  color: #fff;
  text-align: center;
  max-width: 70vw;
  line-height: 1.15;
  animation: dennisTitleFade 1.6s ease forwards;
}

@keyframes dennisTitleFade {
  0%   { opacity: 0; transform: translateY(10px); }
  20%  { opacity: 1; transform: translateY(0); }
  65%  { opacity: 1; }
  100% { opacity: 0; }
}

/*
  clip-path morphs from full rectangle to a dome/arch at the top.
  Both states use identical point counts so CSS interpolates smoothly.
  The arch is a semicircle centred at top-centre (50% 0%), r ≈ 55vw worth.
  After archforming, opacity fades to 0.
*/
@keyframes dennisArch {
  0% {
    opacity: 1;
    clip-path: polygon(
      0% 0%, 100% 0%,
      105% 100%, 103% 100%, 98% 100%, 89% 100%,
      78% 100%, 64% 100%, 50% 100%, 36% 100%,
      22% 100%, 11% 100%, 2% 100%, -3% 100%, -5% 100%
    );
  }
  75% {
    opacity: 1;
    clip-path: polygon(
      0% 0%, 100% 0%,
      105%  0%,  103%  9%,  98% 17%,  89% 24%,
       78% 30%,   64% 34%,  50% 35%,  36% 34%,
       22% 30%,   11% 24%,   2% 17%,  -3%  9%,  -5%  0%
    );
  }
  100% {
    opacity: 0;
    clip-path: polygon(
      0% 0%, 100% 0%,
      105%  0%,  103%  9%,  98% 17%,  89% 24%,
       78% 30%,   64% 34%,  50% 35%,  36% 34%,
       22% 30%,   11% 24%,   2% 17%,  -3%  9%,  -5%  0%
    );
  }
}

/* Remove from layout once done so it doesn't block interactions */
.dennis-overlay.dennis-done {
  display: none;
}
</style>

<script>
  // Remove overlay from DOM after animation completes (0.4s delay + 1.2s anim = 1.6s)
  const overlay = document.getElementById('dennisOverlay');
  if (overlay) {
    setTimeout(() => overlay.classList.add('dennis-done'), 1650);
  }
</script>
