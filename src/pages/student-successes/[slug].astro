---
import ArtfulyLayout from '../../layouts/ArtfulyLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const successes = await getCollection('studentSuccesses');
  return successes.map(s => ({ params: { slug: s.data.slug }, props: { story: s } }));
}

const { story } = Astro.props;
const d = story.data;
const { Content } = await render(story);

const displayDate = d.date
  ? new Date(d.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';

const allSuccesses = await getCollection('studentSuccesses');
const relatedStories = allSuccesses
  .filter(s => s.data.slug !== d.slug)
  .sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''))
  .slice(0, 3);
---

<ArtfulyLayout title={`${d.title} | Student Successes — Artfuly`} description={d.description} ogImage={d.heroImage}>
  <script async data-uid="b7b7a29039" src="https://artfuly.kit.com/b7b7a29039/index.js" slot="head"></script>

  <!-- TITLE HERO -->
  <div class="articles-section-top">
    <div class="a-container w-container">
      <div class="a-des-insight-title" style="color:rgba(255,255,255,0.6); margin-bottom:12px; grid-area:1/1/2/5; text-align:left">STUDENT SUCCESS STORY</div>
      <h1 class="h1-small-white" style="grid-area:2/1/3/5; padding-left:0">{d.title}</h1>
    </div>
  </div>

  <!-- HERO IMAGE -->
  {d.heroImage && (
    <div class="section-47 section-47--has-btn">
      <address style={`background-image:url("${d.heroImage}")`} class="div-with-collection-image">
        <div class="gradient-div"></div>
      </address>
      <div class="article-hero-btn-wrap">
        <button class="article-subscribe-btn" data-formkit-toggle="b7b7a29039">Subscribe</button>
      </div>
    </div>
  )}

  <!-- AUTHOR / DATE -->
  <div class="section-48">
    <div class="w-container">
      <div class="w-layout-grid grid-14">
        <a class="link-block-14 w-inline-block" href="/rachael-page/" style="grid-area:1/1/2/2; justify-self:center">
          <div class="a-div-right-align">
            <img
              class="article-round-image"
              src={d.authorImage ?? '/images/site/rachael-page-round.png'}
              width="60" height="60"
              alt={d.authorName ?? 'Rachael Page'}
              loading="lazy"
            />
          </div>
        </a>
        <div class="link-block-14" style="grid-area:1/2/2/3; place-self:center start">
          <div class="a-div-left-align">
            <div class="_16px-label">{d.authorName ?? 'Rachael Page'}</div>
          </div>
        </div>
        <div class="link-block-14" style="grid-area:1/3/2/4; place-self:center start">
          <div class="a-div-left-align">
            <div class="_16px-label">{displayDate}</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ARTICLE BODY -->
  <div class="section-31">
    <div class="a-4col-grid-container w-container">
      <div class="w-richtext" style="grid-area:2/1/3/5; align-self:start">
        <Content />
      </div>
    </div>
  </div>

  <!-- SHARE -->
  <div class="section-46">
    <div class="container-1214 w-container">
      <div class="paragraph-grey">Share this on:</div>
      <div class="sharethis-inline-share-buttons"></div>
    </div>
  </div>

  <!-- MORE STUDENT STORIES (if any exist) -->
  {relatedStories.length > 0 && (
    <section class="section_layout250">
      <div class="padding-global-4">
        <div class="container-large-2">
          <div class="padding-section-large-4">
            <div class="layout250_component">
              <div class="margin-bottom margin-xxlarge">
                <div class="max-width-large-2">
                  <h3 class="heading-76">More student success stories</h3>
                </div>
              </div>
              <div class="w-layout-grid layout250_list">
                {relatedStories.map(s => (
                  <a href={`/student-successes/${s.data.slug}/`} class="w-inline-block layout250_card">
                    <div>
                      {s.data.heroImage && (
                        <img loading="lazy" alt={s.data.title} src={s.data.heroImage} class="layout250_image" />
                      )}
                      <div class="margin-bottom margin-xsmall">
                        <h3 class="left">{s.data.title}</h3>
                        {s.data.description && <p class="left">{s.data.description}</p>}
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- EMAIL CTA -->
  <section class="section_cta8" id="email-signup">
    <div class="padding-global-3">
      <div class="container-large">
        <div class="padding-section-large-3">
          <div class="cta8_component">
            <div class="cta8_content">
              <div class="max-width-large">
                <div class="margin-bottom margin-xsmall">
                  <div class="margin-bottom margin-xsmall">
                    <div class="a-des-insight-title">WEEKLY EMAIL (FREE)</div>
                  </div>
                  <h2 class="white h2insights">The Design Edge</h2>
                </div>
                <p class="white right">Keep your design skills up to date with videos,<br />AI workflows, tutorials, ways to earn $$$ and free resources.<br /><a href="https://artfuly.kit.com/posts" target="_blank" rel="noopener noreferrer" style="font-size: inherit; font-weight: 700; text-decoration: underline; color: inherit;">See past email newsletters.</a></p>
                <p class="small-white-body">Unsubscribe anytime.</p>
              </div>
            </div>
            <div class="html-embed-7 w-embed w-script">
              <script async data-uid="eb98b5a075" src="https://artfuly.ck.page/eb98b5a075/index.js"></script>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOK A SESSION CTA -->
  <div style="text-align:center; padding:60px 20px; background:#fff;">
    <p style="font-family:'Montserrat',sans-serif; font-size:18px; font-weight:700; color:#233030; margin-bottom:20px;">Want results like this for your own project?</p>
    <a href="/booking-mentorship" style="display:inline-block; background:#ee7c7b; color:#fff; font-family:'Montserrat',sans-serif; font-size:13px; font-weight:700; padding:14px 32px; border-radius:30px; text-decoration:none;">Book a 1:1 session →</a>
  </div>

</ArtfulyLayout>
