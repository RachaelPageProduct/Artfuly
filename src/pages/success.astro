---
import ArtfulyLayout from '../layouts/ArtfulyLayout.astro';
---

<ArtfulyLayout title="Success! — Artfuly" description="You've successfully signed up.">
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <div class="success-page">
    <div class="success-inner">
      <h1>Success!</h1>
      <p class="success-body">
        You may receive a double opt-in email, if so,<br>
        please click the '<strong>Confirm</strong>' button
      </p>
      <p class="success-body">
        Not found the email? <strong>Check your spam</strong><br>
        (and add <strong>hi@artfuly.com</strong> to your address book)
      </p>
      <div class="success-buttons">
        <a href="/design-resources" class="success-btn">To the design resources</a>
        <a href="https://www.youtube.com/@artfulydesign/videos" target="_blank" rel="noopener" class="success-btn">Watch tutorials on youtube</a>
      </div>
    </div>
  </div>
</ArtfulyLayout>

<style>
  .success-page {
    background-color: #048ba2;
    min-height: calc(100vh - 70px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }
  .success-inner {
    text-align: center;
    max-width: 640px;
  }
  h1 {
    font-size: clamp(2.8rem, 8.4vw, 4.9rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 2rem;
    line-height: 1;
    text-align: center !important;
  }
  .success-body {
    color: #fff;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 0 1.5rem;
    text-align: center;
  }
  .success-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }
  .success-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border: 2px solid rgba(255,255,255,0.4);
    border-radius: 50px;
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    background: rgba(255,255,255,0.1);
    transition: background 0.2s, border-color 0.2s;
  }
  .success-btn:hover {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.7);
  }
</style>
