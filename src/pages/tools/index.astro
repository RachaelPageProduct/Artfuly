---
import ArtfulyLayout from '../../layouts/ArtfulyLayout.astro';
import BookPromo from '../../components/BookPromo.astro';

const tools = [
  {
    slug: 'pattern-trend-report',
    title: 'Monthly Spoonflower Pattern Trend Report',
    description: 'AI-generated monthly trend intelligence for Spoonflower designers — interior pattern directions, colour forecasts, SS27 trade show analysis and personalised design opportunities.',
    img: '/images/tools/pattern-trend-report.svg',
    cta: 'View sample report →',
    external: false,
  },
  {
    slug: '3d-book-cover-generator',
    title: '3D Book Cover Generator for Amazon',
    description: 'Turn your flat ebook cover into a professional 3D book mockup for Amazon listings — free, instant, no signup. Upload your cover and download a JPG or PNG.',
    img: '/images/tools/book-cover-3d.png',
    cta: 'Generate your cover →',
    external: false,
  },
  {
    slug: 'ai-art-styles',
    title: 'Art Styles for AI Prompts',
    description: '130 art styles grouped by movement — use as prompts for Midjourney, DALL·E, Firefly and other image generation tools. Hover any card to reveal a description, click to copy the style name.',
    img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Mona_Lisa%2C_by_Leonardo_da_Vinci%2C_from_C2RMF_retouched.jpg/500px-Mona_Lisa%2C_by_Leonardo_da_Vinci%2C_from_C2RMF_retouched.jpg',
    cta: 'Open tool →',
    external: false,
  },
  {
    slug: 'ticklists',
    title: 'Ticklists — Routines & Lists for optimised productivity',
    description: 'An app for daily and weekly routines that recycles your items with tags and tick resets. Items can be sorted into sections, auto-arranged based on location and synced live with your household.',
    img: '/images/tools/ticklists-tool-card.png',
    cta: 'Visit Ticklists →',
    external: false,
  },
  {
    href: '/top-ux-resources',
    title: 'Top UX & UI Resources',
    description: '40+ hand-picked tools, fonts, images, colour pickers, inspiration and learning resources for designers — filterable by category.',
    img: '/images/webflow-cdn/top-ux-resources-hero.png',
    cta: 'Browse resources →',
    external: false,
  },
];
---

<ArtfulyLayout
  title="Design Tools — Artfuly"
  description="Free tools for designers — art style references, prompt guides and more."
>

  <!-- HERO -->
  <div class="articles-section-top">
    <div class="a-container w-container">
      <div class="a-des-insight-title" style="color:rgba(255,255,255,0.6); margin-bottom:12px; grid-area:1/1/2/5; text-align:left">FREE TOOLS</div>
      <h1 class="h1-small-white" style="grid-area:2/1/3/5; padding-left:0">Design &amp; Workflow Tools</h1>
    </div>
  </div>

  <!-- TOOLS GRID -->
  <section class="dr-listing-section">
    <div class="w-container">
      <ul class="dr-listing-grid">
        {tools.map(t => (
          <li class="dr-listing-card">
            <a href={t.href ?? `/tools/${t.slug}/`} class="dr-listing-card__link">
              <img src={t.img} alt={t.title} class="dr-listing-card__img" loading="lazy" />
              <div class="dr-listing-card__body">
                <h2 class="dr-listing-card__title">{t.title}</h2>
                <p class="dr-listing-card__desc">{t.description}</p>
                <span class="dr-listing-card__cta">{t.cta}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SPOONFLOWER BOOK PROMO -->
  <BookPromo />

  <!-- EMAIL CTA -->
  <section class="section_cta8" id="email-signup">
    <div class="padding-global-3">
      <div class="container-large">
        <div class="padding-section-large-3">
          <div class="cta8_component">
            <div class="cta8_content">
              <div class="max-width-large">
                <div class="margin-bottom margin-xsmall">
                  <div class="margin-bottom margin-xsmall">
                    <div class="a-des-insight-title">WEEKLY EMAIL (FREE)</div>
                  </div>
                  <h2 class="white h2insights">The Design Edge</h2>
                </div>
                <p class="white right">Keep your design skills up to date with videos,<br />AI workflows, tutorials, ways to earn $$$ and free resources.<br /><a href="https://artfuly.kit.com/posts" target="_blank" rel="noopener noreferrer" style="font-size: inherit; font-weight: 700; text-decoration: underline; color: inherit;">See past email newsletters.</a></p>
                <p class="small-white-body">Unsubscribe anytime.</p>
              </div>
            </div>
            <div class="html-embed-7 w-embed w-script">
              <script async data-uid="eb98b5a075" src="https://artfuly.ck.page/eb98b5a075/index.js"></script>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</ArtfulyLayout>

<style>
  .dr-listing-section {
    background: #fff;
    padding: 64px 0 80px;
  }
  .dr-listing-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  .dr-listing-card {
    display: flex;
  }
  .dr-listing-card__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid #e0eded;
    transition: box-shadow 0.18s;
  }
  .dr-listing-card__link:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.10); opacity: 1; }
  .dr-listing-card__img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }
  .dr-listing-card__body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .dr-listing-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #233030;
    margin: 0;
    line-height: 1.35;
  }
  .dr-listing-card__link:hover .dr-listing-card__title { color: #3ba89c; }
  .dr-listing-card__desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    color: #555;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .dr-listing-card__cta {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #3ba89c;
    margin-top: 4px;
  }
  @media screen and (max-width: 767px) {
    .dr-listing-grid { grid-template-columns: 1fr; }
  }
</style>
