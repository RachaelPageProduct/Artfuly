---
import ArtfulyLayout from '../../layouts/ArtfulyLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('travel');
  return articles.map(a => ({ params: { slug: a.data.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const d = article.data;
const { Content } = await render(article);

const displayDate = d.date
  ? new Date(d.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';

const allArticles = await getCollection('travel');
const relatedArticles = allArticles
  .filter(a => a.data.slug !== d.slug && a.data.published)
  .sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''))
  .slice(0, 3);
---

<ArtfulyLayout
  title={`${d.titleTag || d.title} | Artfuly`}
  description={d.metaDescription || d.description}
  ogImage={d.heroImage}
  ogType="article"
>
  {d.slug === 'how-to-buy-a-property-with-cash-no-mortgage' && (
    <script type="application/ld+json" slot="head" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to buy a property with cash (no mortgage)",
      "description": "Tips for saving enough money to buy a house or land outright without a mortgage, based on personal experience in Germany.",
      "step": [
        { "@type": "HowToStep", "position": 1, "name": "Eliminate rent", "text": "Find a way to NOT pay rent — live in a campervan, a shed, or with parents. Never pay to hire assets from other people." },
        { "@type": "HowToStep", "position": 2, "name": "Limit all unnecessary outgoings", "text": "Drink tap water, never eat out except for a birthday dinner each year. Cut all entertainment spending." },
        { "@type": "HowToStep", "position": 3, "name": "Buy cheap clothing", "text": "Buy the cheapest clothes, but invest in good running trainers to stay healthy and avoid gym membership costs." },
        { "@type": "HowToStep", "position": 4, "name": "Invest every saving", "text": "Put any saved money into stocks, ETFs, bonds, or a high-interest savings account." },
        { "@type": "HowToStep", "position": 5, "name": "Don't scrimp on essentials", "text": "Always buy good quality food and any assets truly necessary for earning income, such as a reliable work vehicle." }
      ]
    })} />
  )}

  <!-- TITLE HERO -->
  <div class="articles-section-top">
    <div class="a-container w-container">
      <h1 class="h1-small-white" style="grid-area:1/1/2/5">{d.title}</h1>
    </div>
  </div>

  <!-- HERO IMAGE -->
  {d.heroImage && (
    <div class="section-47">
      <address style={`background-image:url("${d.heroImage}")`} class="div-with-collection-image">
        <div class="gradient-div"></div>
      </address>
    </div>
  )}

  <!-- AUTHOR / DATE -->
  <div class="section-48">
    <div class="w-container">
      <div class="w-layout-grid grid-14">
        <a class="link-block-14 w-inline-block" href="/rachael-page/" style="grid-area:1/1/2/2; justify-self:center">
          <div class="a-div-right-align">
            <img
              class="article-round-image"
              src="/images/webflow-cdn/657c47f547655d5eb1c9eede_me2019-etch-trasparent.png"
              width="60" height="60"
              alt="Rachael Page"
              loading="lazy"
            />
          </div>
        </a>
        <div class="link-block-14" style="grid-area:1/2/2/3; place-self:center start">
          <div class="a-div-left-align">
            <div class="_16px-label">Rachael Page</div>
          </div>
        </div>
        <div class="link-block-14" style="grid-area:1/3/2/4; place-self:center start">
          <div class="a-div-left-align">
            <div class="_16px-label">{displayDate}</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- INTRO HEADING + ARTICLE BODY -->
  <div class="section-31">
    <div class="a-4col-grid-container w-container">
      {d.introHeading && (
        <div style="grid-area:1/1/2/5">
          <h2 class="h2-small-blue-blog">{d.introHeading}</h2>
        </div>
      )}
      <div class="w-richtext" style="grid-area:2/1/3/5; align-self:start">
        <Content />
      </div>
    </div>
  </div>

  <!-- SHARE -->
  <div class="section-46">
    <div class="container-1214 w-container">
      <div class="paragraph-grey">Share this on:</div>
      <div class="sharethis-inline-share-buttons"></div>
    </div>
  </div>

  <!-- MORE TRAVEL ARTICLES -->
  {relatedArticles.length > 0 && (
    <section class="section_layout250">
      <div class="padding-global-4">
        <div class="container-large-2">
          <div class="padding-section-large-4">
            <div class="layout250_component">
              <div class="margin-bottom margin-xxlarge">
                <div class="max-width-large-2">
                  <h3 class="heading-76">More travel articles</h3>
                </div>
              </div>
              <div class="w-layout-grid layout250_list">
                {relatedArticles.map(a => (
                  <a href={`/travel/${a.data.slug}/`} class="w-inline-block layout250_card">
                    <div>
                      {(a.data.thumbnailImage || a.data.heroImage) && (
                        <img loading="lazy" alt={a.data.title} src={a.data.thumbnailImage || a.data.heroImage} class="layout250_image" />
                      )}
                      <div class="margin-bottom margin-xsmall">
                        <h3 class="left">{a.data.title}</h3>
                        <div class="layout250_item">
                          {a.data.description && <p class="left">{a.data.description}</p>}
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- EMAIL CTA -->
  <section class="section_cta8" id="email-signup">
    <div class="padding-global-3">
      <div class="container-large">
        <div class="padding-section-large-3">
          <div class="cta8_component">
            <div class="cta8_content">
              <div class="max-width-large">
                <div class="margin-bottom margin-xsmall">
                  <div class="margin-bottom margin-xsmall">
                    <div class="a-des-insight-title">WEEKLY EMAIL (FREE)</div>
                  </div>
                  <h2 class="white h2insights">The Design Edge</h2>
                </div>
                <p class="white right">Keep your design skills up to date with videos,<br />AI workflows, tutorials, ways to earn $$$ and free resources.<br /><a href="https://artfuly.kit.com/posts" target="_blank" rel="noopener noreferrer" style="font-size: inherit; font-weight: 700; text-decoration: underline; color: inherit;">See past email newsletters.</a></p>
                <p class="small-white-body">Unsubscribe anytime.</p>
              </div>
            </div>
            <div class="html-embed-7 w-embed w-script">
              <script async data-uid="eb98b5a075" src="https://artfuly.ck.page/eb98b5a075/index.js"></script>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</ArtfulyLayout>
