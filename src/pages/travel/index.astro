---
import ArtfulyLayout from '../../layouts/ArtfulyLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('travel');
const sorted = allArticles
  .filter(a => a.data.published)
  .sort((a, b) => {
    if (!a.data.date && !b.data.date) return 0;
    if (!a.data.date) return 1;
    if (!b.data.date) return -1;
    return b.data.date.localeCompare(a.data.date);
  });
---

<ArtfulyLayout
  title="Lifestyle & Travel — Artfuly"
  description="Location independent life, slow travel, remote working, and escaping the rat race — by Rachael Page."
>

  <!-- HERO -->
  <div class="articles-section-top">
    <div class="a-container w-container">
      <div class="a-des-insight-title" style="color:rgba(255,255,255,0.6); margin-bottom:12px; grid-area:1/1/2/5; text-align:left">LIFESTYLE & TRAVEL</div>
      <h1 class="h1-small-white" style="grid-area:2/1/3/5; padding-left:0">Lifestyle & Travel</h1>
    </div>
  </div>

  <!-- ARTICLE GRID -->
  <section class="dr-listing-section">
    <div class="w-container">
      {sorted.length === 0 ? (
        <p style="font-family:'Montserrat',sans-serif; color:#555; text-align:center; padding:60px 0;">Articles coming soon.</p>
      ) : (
        <ul class="dr-listing-grid">
          {sorted.map(a => {
            const d = a.data;
            const img = d.thumbnailImage || d.heroImage || null;
            const displayDate = d.date
              ? new Date(d.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
              : '';
            return (
              <li class="dr-listing-card">
                <a href={`/travel/${d.slug}/`} class="dr-listing-card__link">
                  {img && (
                    <img
                      src={img}
                      alt={d.title}
                      class="dr-listing-card__img"
                      loading="lazy"
                    />
                  )}
                  {!img && <div class="dr-listing-card__img dr-listing-card__img--placeholder"></div>}
                  <div class="dr-listing-card__body">
                    {displayDate && <p class="dr-listing-card__date">{displayDate}</p>}
                    <h2 class="dr-listing-card__title">{d.title}</h2>
                    {d.description && <p class="dr-listing-card__desc">{d.description}</p>}
                    <span class="dr-listing-card__cta">Read article →</span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>

  <!-- EMAIL CTA -->
  <section class="section_cta8" id="email-signup">
    <div class="padding-global-3">
      <div class="container-large">
        <div class="padding-section-large-3">
          <div class="cta8_component">
            <div class="cta8_content">
              <div class="max-width-large">
                <div class="margin-bottom margin-xsmall">
                  <div class="margin-bottom margin-xsmall">
                    <div class="a-des-insight-title">LEARN BY EMAIL (FREE)</div>
                  </div>
                  <h2 class="white h2insights">Design Principles</h2>
                </div>
                <p class="white right">Learn by watching me apply key design principles<br />1 email per week with videos &amp; free resources</p>
                <p class="small-white-body">Unsubscribe anytime.</p>
              </div>
            </div>
            <div class="html-embed-7 w-embed w-script">
              <script async data-uid="eb98b5a075" src="https://artfuly.ck.page/eb98b5a075/index.js"></script>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</ArtfulyLayout>

<style>
  .dr-listing-section {
    background: #fff;
    padding: 64px 0 80px;
  }
  .dr-listing-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  .dr-listing-card { display: flex; }
  .dr-listing-card__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid #e0eded;
    transition: box-shadow 0.18s;
  }
  .dr-listing-card__link:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.10); opacity: 1; }
  .dr-listing-card__img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }
  .dr-listing-card__img--placeholder {
    background: #e0eded;
    height: 180px;
  }
  .dr-listing-card__body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .dr-listing-card__date {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .dr-listing-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #233030;
    margin: 0;
    line-height: 1.35;
  }
  .dr-listing-card__link:hover .dr-listing-card__title { color: #3ba89c; }
  .dr-listing-card__desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    color: #555;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .dr-listing-card__cta {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #3ba89c;
    margin-top: 4px;
  }
  @media screen and (max-width: 991px) {
    .dr-listing-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (max-width: 767px) {
    .dr-listing-grid { grid-template-columns: 1fr; }
  }
</style>
